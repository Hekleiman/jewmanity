---
interface Props {
  imagePosition?: string;
}

const { imagePosition = 'center 30%' } = Astro.props;
---

<section id="donate-hero" class="relative min-h-[70vh] overflow-hidden lg:min-h-[80vh]">
  <img src="/images/hero/donate.jpg" alt="Supporting healing through generous donations" class="absolute inset-0 h-full w-full object-cover" style={`object-position: ${imagePosition}`} width="1920" height="1080" loading="eager" />
  <div class="absolute inset-0 bg-black/50"></div>

  <div class="relative z-10 mx-auto flex min-h-[70vh] max-w-[1200px] flex-col items-center gap-10 px-6 pt-32 pb-16 lg:min-h-[80vh] lg:flex-row lg:items-center lg:gap-16 lg:pt-24">
    <!-- Left: Text -->
    <div class="lg:w-1/2">
      <h1 class="font-heading text-[clamp(32px,5vw,48px)] font-medium leading-[1.1] text-white">
        Give Today. Create Lasting Impact.
      </h1>
      <p class="mt-6 font-body text-[clamp(15px,2vw,18px)] leading-relaxed text-white/85">
        Your donation directly funds healing retreats, community care, and trauma-informed programs like Heads Up—supporting Israelis and Jewish individuals on their journey to recovery.
      </p>
      <p class="mt-6 font-heading text-sm font-normal leading-relaxed text-white/75 italic">
        We are an official tax exempt organization with a 501(c)(3) classification. All donors can deduct contributions.
      </p>
    </div>

    <!-- Right: Donorbox donation widget -->
    <!-- Note: Widget header/button color must be set in Donorbox dashboard: Campaign > Design > Primary Color > #3783A3 -->
    <div class="w-full max-w-[440px] lg:w-1/2">
      <script src="https://donorbox.org/widget.js" paypalexpress="false" is:inline></script>
      <iframe
        src="https://donorbox.org/embed/jewmanity-donation?default_interval=o&hide_donation_meter=true"
        name="donorbox"
        allowpaymentrequest="allowpaymentrequest"
        seamless="seamless"
        frameborder="0"
        scrolling="no"
        height="490px"
        width="100%"
        style="max-width:440px; min-width:250px; max-height:none!important; border:none;"
      ></iframe>
    </div>
  </div>
</section>
