---
interface Props {}

interface LineItem {
  icon: string;
  title: string;
  description: string;
  amount: string;
}

const items: LineItem[] = [
  {
    icon: '✈️',
    title: 'International Flights',
    description: 'Round-trip travel from Israel to San Diego',
    amount: '$1,200',
  },
  {
    icon: '🏠',
    title: 'Housing & Accommodations',
    description: 'Safe, comfortable lodging for the entire duration',
    amount: '$800',
  },
  {
    icon: '💊',
    title: 'Therapy & Clinical Support',
    description: 'Professional trauma therapy, mindfulness, and counseling',
    amount: '$1,500',
  },
  {
    icon: '🍽️',
    title: 'Meals & Nutrition',
    description: 'Nourishing meals throughout the program',
    amount: '$400',
  },
  {
    icon: '🎯',
    title: 'Program Activities & Logistics',
    description: 'Workshops, group sessions, and recreational experiences',
    amount: '$600',
  },
];
---

<section id="cost-breakdown" class="bg-bg-section-alt py-16 md:py-20 lg:py-24">
  <div class="mx-auto max-w-[800px] px-6 lg:max-w-[960px]">
    <div class="mb-12 text-center" data-animate="fade-up">
      <h2 class="font-heading text-[clamp(28px,4vw,36px)] font-medium leading-tight text-text-heading">
        How Your Donation is Used
      </h2>
      <p class="mx-auto mt-4 max-w-[600px] font-body text-base leading-relaxed text-text-body">
        We believe in complete transparency. Here's a breakdown of the average cost to support one participant through a healing retreat.
      </p>
    </div>

    <div data-animate="stagger" class="overflow-hidden rounded-[24px] border-[0.5px] border-border-card bg-white shadow-[0px_16px_32px_rgba(12,12,13,0.1),0px_4px_4px_rgba(12,12,13,0.05)]">
      {items.map((item, index) => (
        <div class:list={[
          'flex items-center gap-4 px-6 py-5',
          index < items.length - 1 && 'border-b border-border-card',
        ]}>
          <span class="shrink-0 text-xl" aria-hidden="true">{item.icon}</span>
          <div class="flex-1">
            <h3 class="font-body text-base font-medium text-text-heading">{item.title}</h3>
            <p class="mt-0.5 font-body text-sm text-text-muted">{item.description}</p>
          </div>
          <span class="shrink-0 font-heading text-base font-medium text-text-heading">{item.amount}</span>
        </div>
      ))}

      <!-- Total -->
      <div class="flex items-center gap-4 border-t-2 border-primary/20 bg-primary/5 px-6 py-5">
        <div class="flex-1">
          <h3 class="font-heading text-base font-medium text-text-heading">Average Cost Per Participant</h3>
        </div>
        <span class="font-heading text-xl font-medium text-primary">$4,500</span>
      </div>
    </div>

    <!-- Disclaimer -->
    <div class="mt-6 rounded-[16px] border border-primary/20 bg-primary-light p-5">
      <p class="font-body text-sm leading-relaxed text-text-body">
        <strong class="font-medium text-text-heading">Responsible Stewardship:</strong> Every dollar is carefully allocated to maximize impact. Administrative costs are kept minimal, ensuring your contribution directly supports healing programs.
      </p>
    </div>
  </div>
</section>
