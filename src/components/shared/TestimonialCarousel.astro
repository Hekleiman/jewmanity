---
interface Testimonial {
  quote: string;
  author: string;
  context: string;
}

interface Props {
  heading: string;
  subtitle?: string;
  testimonials: Testimonial[];
}

const { heading, subtitle, testimonials } = Astro.props;
const carouselId = `tc-${Math.random().toString(36).slice(2, 8)}`;
---

<section id="testimonials" class="bg-bg-section-alt py-16 md:py-20 lg:py-24">
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="mb-12 text-center">
      <h2 class="font-heading text-[clamp(28px,4vw,36px)] font-medium leading-tight text-text-heading">
        {heading}
      </h2>
      {subtitle && (
        <p class="mx-auto mt-4 max-w-[700px] font-body text-[15px] leading-relaxed text-text-body md:text-base">
          {subtitle}
        </p>
      )}
    </div>

    <div class="mx-auto max-w-[800px]">
      <div
        class="tc-carousel relative rounded-2xl border-[0.5px] border-border-card bg-white p-8 shadow-[0px_8px_16px_rgba(12,12,13,0.06),0px_2px_4px_rgba(12,12,13,0.04)] md:p-10"
        data-carousel-id={carouselId}
      >
        <!-- Quote icon -->
        <svg class="mb-4 h-8 w-8 text-primary/30" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
          <path d="M10 8C5.6 8 2 11.6 2 16v8h8v-8H6c0-2.2 1.8-4 4-4V8zm16 0c-4.4 0-8 3.6-8 8v8h8v-8h-4c0-2.2 1.8-4 4-4V8z"/>
        </svg>

        <div class="tc-slides relative pb-2">
          {testimonials.map((t, i) => (
            <div
              class:list={[
                "tc-slide transition-opacity duration-500",
                i === 0 ? "opacity-100 relative" : "opacity-0 pointer-events-none absolute inset-0",
              ]}
              data-index={i}
            >
              <blockquote>
                <p class="font-body text-base italic leading-relaxed text-text-body md:text-lg">
                  "{t.quote}"
                </p>
              </blockquote>
              <p class="mt-6 font-body text-sm font-medium text-text-heading">
                &mdash; {t.author}
              </p>
              <p class="mt-1 font-body text-sm text-text-muted">
                {t.context}
              </p>
            </div>
          ))}
        </div>
      </div>

      <!-- Navigation -->
      <div class="mt-8 flex items-center justify-center gap-6">
        <button
          class="tc-prev flex h-8 w-8 items-center justify-center rounded-full border border-border-card text-text-muted transition-colors hover:border-primary hover:text-primary"
          aria-label="Previous testimonial"
          data-carousel-id={carouselId}
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="flex items-center gap-2" role="tablist" aria-label="Testimonial navigation">
          {testimonials.map((_, i) => (
            <button
              type="button"
              class:list={[
                "tc-dot h-2.5 w-2.5 rounded-full transition-colors duration-300",
                i === 0 ? "bg-primary" : "bg-gray-300",
              ]}
              role="tab"
              aria-selected={i === 0 ? "true" : "false"}
              aria-label={`Testimonial ${i + 1}`}
              data-index={i}
              data-carousel-id={carouselId}
            ></button>
          ))}
        </div>
        <button
          class="tc-next flex h-8 w-8 items-center justify-center rounded-full border border-border-card text-text-muted transition-colors hover:border-primary hover:text-primary"
          aria-label="Next testimonial"
          data-carousel-id={carouselId}
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('.tc-carousel').forEach((carousel) => {
    const id = carousel.dataset.carouselId!;
    const slides = carousel.querySelectorAll<HTMLElement>('.tc-slide');
    const dots = document.querySelectorAll<HTMLButtonElement>(`.tc-dot[data-carousel-id="${id}"]`);
    const prevBtn = document.querySelector<HTMLButtonElement>(`.tc-prev[data-carousel-id="${id}"]`);
    const nextBtn = document.querySelector<HTMLButtonElement>(`.tc-next[data-carousel-id="${id}"]`);
    const total = slides.length;
    let current = 0;
    let timer: ReturnType<typeof setInterval> | null = null;

    function goTo(index: number) {
      slides.forEach((slide, i) => {
        if (i === index) {
          slide.classList.remove('opacity-0', 'pointer-events-none', 'absolute', 'inset-0');
          slide.classList.add('opacity-100', 'relative');
        } else {
          slide.classList.add('opacity-0', 'pointer-events-none', 'absolute', 'inset-0');
          slide.classList.remove('opacity-100', 'relative');
        }
      });
      dots.forEach((dot, i) => {
        dot.classList.toggle('bg-primary', i === index);
        dot.classList.toggle('bg-gray-300', i !== index);
        dot.setAttribute('aria-selected', i === index ? 'true' : 'false');
      });
      current = index;
    }

    function next() { goTo((current + 1) % total); }
    function prev() { goTo((current - 1 + total) % total); }

    function startAutoplay() {
      if (timer) clearInterval(timer);
      timer = setInterval(next, 6000);
    }

    function stopAutoplay() {
      if (timer) { clearInterval(timer); timer = null; }
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        goTo(Number(dot.dataset.index));
        stopAutoplay();
        startAutoplay();
      });
    });

    prevBtn?.addEventListener('click', () => { prev(); stopAutoplay(); startAutoplay(); });
    nextBtn?.addEventListener('click', () => { next(); stopAutoplay(); startAutoplay(); });

    carousel.addEventListener('mouseenter', stopAutoplay);
    carousel.addEventListener('mouseleave', startAutoplay);

    // Touch swipe
    let touchStartX = 0;
    carousel.addEventListener('touchstart', (e) => {
      touchStartX = (e as TouchEvent).touches[0].clientX;
      stopAutoplay();
    }, { passive: true });

    carousel.addEventListener('touchend', (e) => {
      const diff = touchStartX - (e as TouchEvent).changedTouches[0].clientX;
      if (Math.abs(diff) > 50) {
        if (diff > 0) next(); else prev();
      }
      startAutoplay();
    }, { passive: true });

    startAutoplay();
  });
</script>
