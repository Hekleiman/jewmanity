  const select = document.getElementById('crisis-country-select') as HTMLSelectElement;
  const results = document.getElementById('crisis-results') as HTMLDivElement;

  select?.addEventListener('change', () => {
    const code = select.value;
    if (!code || !crisisData[code]) {
      results.innerHTML = '<p class="font-body text-sm leading-relaxed text-text-muted">Select your country to find local crisis support numbers</p>';
      return;
    }
    const data = crisisData[code];
    results.innerHTML = '<div class="space-y-3">' +
      data.lines.map(line =>
        '<div>' +
          '<p class="font-body text-sm font-medium text-text-heading">' + line.label + '</p>' +
          '<a href="tel:' + line.tel + '" class="mt-0.5 inline-block font-body text-sm font-medium text-primary transition-colors hover:text-primary-hover">' +
            line.number +
          '</a>' +
        '</div>'
      ).join('') +
    '</div>';
  });
</script>
