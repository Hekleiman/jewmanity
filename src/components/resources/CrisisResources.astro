---
interface CrisisResource {
  name: string;
  description?: string;
  phone?: string;
  url?: string;
  region?: string;
}

interface Props {
  heading?: string;
  introParagraphs?: string[];
  usResources?: CrisisResource[];
}

const fallbackIntroParagraphs: string[] = [
  'If you or someone you love is in immediate danger, please contact emergency services right away. If you are struggling and unsure where to turn, confidential support is available through the resources listed here.',
  'You do not have to face this moment alone. Help is available, and reaching out can be the first step toward relief.',
];

const fallbackUsResources: CrisisResource[] = [
  { name: '988 Suicide & Crisis Lifeline', description: 'Call or Text 988' },
  { name: '911 for immediate emergency' },
  { name: 'Crisis Text Line', description: 'Text HOME to 741741' },
];

const { heading, introParagraphs, usResources } = Astro.props;

const displayHeading = heading || 'Immediate Help & Crisis Resources';
const displayIntroParagraphs = introParagraphs && introParagraphs.length > 0 ? introParagraphs : fallbackIntroParagraphs;
const displayUsResources = usResources && usResources.length > 0 ? usResources : fallbackUsResources;
---

<section id="crisis-resources" class="py-16 md:py-20 lg:py-24">
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="flex flex-col gap-10 lg:flex-row lg:gap-16">
      <!-- Intro text -->
      <div class="lg:w-[45%]" data-animate="fade-up">
        <h2 class="font-heading text-[clamp(24px,3.5vw,32px)] font-medium leading-tight text-text-heading">
          {displayHeading}
        </h2>
        {displayIntroParagraphs.map((para, i) => (
          <p class:list={["font-body text-[15px] leading-relaxed text-text-body md:text-base", i === 0 ? "mt-5" : "mt-4"]}>
            {para}
          </p>
        ))}
      </div>

      <!-- Resource cards -->
      <div class="flex flex-col gap-6 sm:flex-row lg:w-[55%]" data-animate="stagger">
        <!-- United States -->
        <div class="flex-1 overflow-hidden rounded-2xl border-[0.5px] border-border-card bg-white shadow-[0px_8px_16px_rgba(12,12,13,0.06),0px_2px_4px_rgba(12,12,13,0.04)]">
          <div class="bg-[#C74E4E] px-6 py-3">
            <h3 class="font-heading text-base font-medium text-white">United States</h3>
          </div>
          <div class="space-y-4 px-6 py-5">
            {displayUsResources.map((r) => (
              <div>
                <p class="font-body text-sm font-medium text-text-heading">{r.name}</p>
                {r.description && (
                  <p class="mt-1 font-body text-sm text-text-body">{r.description}</p>
                )}
              </div>
            ))}
          </div>
        </div>

        <!-- International -->
        <div class="flex-1 overflow-hidden rounded-2xl border-[0.5px] border-border-card bg-white shadow-[0px_8px_16px_rgba(12,12,13,0.06),0px_2px_4px_rgba(12,12,13,0.04)]">
          <div class="bg-[#C74E4E] px-6 py-3">
            <h3 class="font-heading text-base font-medium text-white">International</h3>
          </div>
          <div class="px-6 py-5">
            <label for="crisis-country-select" class="sr-only">Select your country</label>
            <select
              id="crisis-country-select"
              class="w-full rounded-lg border border-primary/40 bg-white px-3 py-2.5 font-body text-sm text-text-heading focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
            >
              <option value="">Select your country</option>
              <option value="AR">Argentina</option>
              <option value="AU">Australia</option>
              <option value="AT">Austria</option>
              <option value="BE">Belgium</option>
              <option value="BR">Brazil</option>
              <option value="CA">Canada</option>
              <option value="CL">Chile</option>
              <option value="CN">China</option>
              <option value="CO">Colombia</option>
              <option value="EG">Egypt</option>
              <option value="FR">France</option>
              <option value="DE">Germany</option>
              <option value="HK">Hong Kong</option>
              <option value="IN">India</option>
              <option value="IE">Ireland</option>
              <option value="IL">Israel</option>
              <option value="IT">Italy</option>
              <option value="JP">Japan</option>
              <option value="MX">Mexico</option>
              <option value="MA">Morocco</option>
              <option value="NL">Netherlands</option>
              <option value="NZ">New Zealand</option>
              <option value="PE">Peru</option>
              <option value="PH">Philippines</option>
              <option value="PL">Poland</option>
              <option value="RU">Russia</option>
              <option value="SG">Singapore</option>
              <option value="ZA">South Africa</option>
              <option value="KR">South Korea</option>
              <option value="ES">Spain</option>
              <option value="SE">Sweden</option>
              <option value="CH">Switzerland</option>
              <option value="TR">Turkey</option>
              <option value="UA">Ukraine</option>
              <option value="AE">United Arab Emirates</option>
              <option value="GB">United Kingdom</option>
            </select>
            <div id="crisis-results" class="mt-4" aria-live="polite">
              <p class="font-body text-sm leading-relaxed text-text-muted">
                Select your country to find local crisis support numbers
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

