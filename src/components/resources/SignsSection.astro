---
interface Props {}

const signs: string[] = [
  'Persistent sadness lasting more than two weeks',
  'Sleep disruption or extreme fatigue',
  'Withdrawal from friends or family',
  'Feeling hopeless or numb',
  'Increased irritability or panic',
  'Difficulty concentrating',
  'Loss of interest in previously enjoyed activities',
];
---

<section id="signs-section" class="bg-bg-section-alt py-16 md:py-20 lg:py-24">
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="flex flex-col items-center gap-10 lg:flex-row lg:gap-16">
      <!-- Text -->
      <div class="lg:w-1/2">
        <h2 class="font-heading text-[clamp(24px,3.5vw,32px)] font-medium leading-tight text-text-heading">
          Signs You Might Need Additional Support
        </h2>
        <p class="mt-5 font-body text-[15px] leading-relaxed text-text-body md:text-base">
          This section helps you self-identify without self-diagnosing.
        </p>
        <ul class="mt-6 space-y-3">
          {signs.map((sign) => (
            <li class="flex items-start gap-3 font-body text-[15px] leading-relaxed text-text-body md:text-base">
              <svg class="mt-1.5 h-4 w-4 shrink-0 text-primary" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <circle cx="8" cy="8" r="3" fill="currentColor"/>
              </svg>
              {sign}
            </li>
          ))}
        </ul>
        <div class="mt-8 rounded-xl border-l-4 border-primary bg-primary-light/50 px-6 py-5">
          <p class="font-body text-sm leading-relaxed text-text-body md:text-[15px]">
            <span class="font-medium text-text-heading">Important Note:</span> If these feel familiar, speaking with a licensed therapist or mental health provider can be a powerful first step.
          </p>
        </div>
      </div>

      <!-- Image placeholder -->
      <div class="lg:w-1/2">
        <img src="/images/sections/resources-signs.jpg" alt="Signs you might need additional mental health support" class="aspect-[4/3] w-full rounded-2xl object-cover" width="600" height="400" loading="lazy" />
      </div>
    </div>
  </div>
</section>
