---
interface Props {
  id: string;
  name: string;
  price: string;
  priceNum: string;
  description: string;
  features: string[];
  image: string;
  slug: string;
}

const { id, name, price, priceNum, description, features, image, slug } = Astro.props;
---

<section id="product-detail" class="pb-16 pt-8 md:pb-20 md:pt-12">
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="flex flex-col gap-10 lg:flex-row">
      <!-- Left: Image gallery -->
      <div class="lg:w-1/2">
        <!-- Main image with nav arrows -->
        <div class="relative aspect-square overflow-hidden rounded-[16px]">
          {image && (
            <img src={image} alt={name} class="absolute inset-0 h-full w-full object-cover" width="600" height="600" loading="eager" />
          )}
          <button
            type="button"
            class="absolute left-3 top-1/2 flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full bg-white/80 text-text-body shadow transition-colors hover:bg-white"
            aria-label="Previous image"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
            </svg>
          </button>
          <button
            type="button"
            class="absolute right-3 top-1/2 flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full bg-white/80 text-text-body shadow transition-colors hover:bg-white"
            aria-label="Next image"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
            </svg>
          </button>
        </div>

        <!-- Thumbnails -->
        <div class="mt-4 grid grid-cols-3 gap-3">
          <div class="aspect-square overflow-hidden rounded-[12px]">
            <img src={image} alt={`${name} - view 1`} class="h-full w-full object-cover" width="200" height="200" loading="lazy" />
          </div>
          <div class="aspect-square overflow-hidden rounded-[12px] bg-gradient-to-br from-primary/10 to-primary/5"></div>
          <div class="aspect-square overflow-hidden rounded-[12px] bg-gradient-to-br from-primary/8 to-primary/3"></div>
        </div>
      </div>

      <!-- Right: Product info -->
      <div class="lg:w-1/2 lg:pt-4">
        <!-- Breadcrumb -->
        <nav aria-label="Breadcrumb" class="mb-4 pt-16 lg:pt-0">
          <ol class="flex items-center gap-1.5 font-body text-sm text-text-muted">
            <li><a href="/shop" class="transition-colors hover:text-primary">Shop</a></li>
            <li aria-hidden="true">&rsaquo;</li>
            <li class="font-medium text-text-heading">{name}</li>
          </ol>
        </nav>

        <div class="flex items-start justify-between gap-4">
          <h1 class="font-heading text-[clamp(26px,4vw,36px)] font-medium leading-tight text-text-heading">
            {name}
          </h1>
          <span class="shrink-0 pt-1 font-heading text-2xl font-medium text-primary">{price}</span>
        </div>

        <p class="mt-4 font-body text-base leading-relaxed text-text-body">
          {description}
        </p>

        <hr class="my-6 border-border-card" />

        <h2 class="font-heading text-lg font-medium text-text-heading">
          What Makes It Special
        </h2>
        <ul class="mt-3 space-y-2.5">
          {features.map((feature) => (
            <li class="flex items-start gap-2 font-body text-sm leading-relaxed text-text-body">
              <span class="mt-1.5 block h-1.5 w-1.5 shrink-0 rounded-full bg-primary" aria-hidden="true"></span>
              <span>{feature}</span>
            </li>
          ))}
        </ul>

        <hr class="my-6 border-border-card" />

        <!-- Quantity selector -->
        <div>
          <label class="mb-2 block font-body text-sm font-medium text-text-heading">Quantity</label>
          <div class="flex items-center gap-0">
            <button
              type="button"
              id="qty-decrease"
              class="flex h-10 w-10 items-center justify-center rounded-l-lg border border-[#DADADA] bg-white font-body text-lg text-text-body transition-colors hover:bg-gray-50"
              aria-label="Decrease quantity"
            >
              &minus;
            </button>
            <div
              id="qty-display"
              class="flex h-10 w-12 items-center justify-center border-y border-[#DADADA] bg-white font-body text-base font-medium text-text-heading"
            >
              1
            </div>
            <button
              type="button"
              id="qty-increase"
              class="flex h-10 w-10 items-center justify-center rounded-r-lg border border-[#DADADA] bg-white font-body text-lg text-text-body transition-colors hover:bg-gray-50"
              aria-label="Increase quantity"
            >
              +
            </button>
          </div>
        </div>

        <!-- Add to Cart -->
        <button
          id="add-to-cart-btn"
          class="snipcart-add-item mt-6 w-full rounded-[100px] bg-primary py-3.5 font-heading text-base font-medium text-white transition-colors hover:bg-primary-hover"
          data-item-id={id}
          data-item-name={name}
          data-item-price={priceNum}
          data-item-url={`/shop/${slug}`}
          data-item-description={description}
          data-item-image={image}
          data-item-quantity="1"
        >
          Add to Cart +
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  const qtyDisplay = document.getElementById('qty-display') as HTMLDivElement;
  const decreaseBtn = document.getElementById('qty-decrease') as HTMLButtonElement;
  const increaseBtn = document.getElementById('qty-increase') as HTMLButtonElement;
  const addToCartBtn = document.getElementById('add-to-cart-btn') as HTMLButtonElement;

  let quantity = 1;

  function updateQuantity(newQty: number): void {
    quantity = Math.max(1, newQty);
    qtyDisplay.textContent = String(quantity);
    addToCartBtn.setAttribute('data-item-quantity', String(quantity));
  }

  decreaseBtn.addEventListener('click', () => updateQuantity(quantity - 1));
  increaseBtn.addEventListener('click', () => updateQuantity(quantity + 1));
</script>
