---
import ProductCard from './ProductCard.astro';

interface Product {
  id: string;
  name: string;
  price: string;
  priceNum: string;
  slug: string;
  description: string;
  image: string;
}

interface Props {
  products?: Product[];
}

const fallbackProducts: Product[] = [
  {
    id: 'heads-up-water-bottle',
    name: 'Heads Up Signature Water Bottle',
    price: '$35',
    priceNum: '35.00',
    slug: 'heads-up-water-bottle',
    description: 'Black Owala Freesip\u00ae Twist water bottle with the Heads Up logo. 100% of proceeds directly support Jewmanity\'s initiatives.',
    image: '/images/products/water-bottle.png',
  },
  {
    id: 'black-trucker-hat',
    name: 'Black Trucker Hat',
    price: '$30',
    priceNum: '30.00',
    slug: 'black-trucker-hat',
    description: 'Embrace style and significance with our Black Trucker Hat, featuring a vibrant dove emblem. Perfect for making a statement while staying comfortable.',
    image: '/images/products/black-trucker-hat.png',
  },
  {
    id: 'pink-trucker-hat',
    name: 'Pink Trucker Hat',
    price: '$30',
    priceNum: '30.00',
    slug: 'pink-trucker-hat',
    description: 'Stand out in style and make a statement with the Jewmanity Logo Hat. Designed for comfort and impact, this hat is perfect for those who value both fashion and ideals.',
    image: '/images/products/pink-trucker-hat.png',
  },
  {
    id: 'travel-shabbat-candle-set',
    name: 'Travel Shabbat Candle Set',
    price: '$30',
    priceNum: '30.00',
    slug: 'travel-shabbat-candle-set',
    description: 'Two tea light ceramic candle holders, 3 boxes of Jewmanity\u00ae matches, 2 tea light candles, and travel pouch',
    image: '/images/products/shabbat-candle-set.jpg',
  },
];

const { products: cmsProducts } = Astro.props;
const products = cmsProducts && cmsProducts.length > 0 ? cmsProducts : fallbackProducts;
---

<section id="product-grid" class="py-16 md:py-20 lg:py-24">
  <div class="mx-auto max-w-[1200px] px-6">
    <h2 class="mb-12 text-center font-heading text-[clamp(28px,4vw,36px)] font-medium leading-tight text-text-heading">
      Our Current Collection
    </h2>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4" data-animate="stagger">
      {products.map((product) => (
        <ProductCard
          id={product.id}
          name={product.name}
          price={product.price}
          priceNum={product.priceNum}
          href={`/shop/${product.slug}`}
          description={product.description}
          image={product.image}
        />
      ))}
    </div>
  </div>
</section>
