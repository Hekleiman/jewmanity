---
interface Props {}
---

<footer class="bg-bg-footer px-6 py-16">
  <div class="mx-auto flex max-w-4xl flex-col items-center gap-12">
    <!-- Social Icons -->
    <div class="flex items-center gap-6">
      <!-- Facebook -->
      <a
        href="https://www.facebook.com/profile.php?id=61577185790846"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Facebook"
        class="flex h-9 w-9 items-center justify-center rounded-[12px] transition-opacity hover:opacity-80"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M18 10C18 5.58 14.42 2 10 2C5.58 2 2 5.58 2 10C2 13.99 4.93 17.3 8.75 17.9V12.31H6.72V10H8.75V8.25C8.75 6.24 9.94 5.13 11.77 5.13C12.65 5.13 13.56 5.29 13.56 5.29V7.25H12.55C11.56 7.25 11.25 7.87 11.25 8.5V10H13.47L13.12 12.31H11.25V17.9C15.07 17.3 18 13.99 18 10Z" fill="white"/>
        </svg>
      </a>

      <!-- Instagram -->
      <a
        href="https://www.instagram.com/jewmanity_"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram"
        class="flex h-9 w-9 items-center justify-center rounded-[12px] transition-opacity hover:opacity-80"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <rect x="2" y="2" width="16" height="16" rx="5" stroke="white" stroke-width="1.5"/>
          <circle cx="10" cy="10" r="4" stroke="white" stroke-width="1.5"/>
          <circle cx="14.5" cy="5.5" r="1" fill="white"/>
        </svg>
      </a>

      <!-- TODO: Add Twitter/X and LinkedIn URLs when available -->
      <!-- Twitter/X -->
      <a
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Twitter"
        class="flex h-9 w-9 items-center justify-center rounded-[12px] transition-opacity hover:opacity-80"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M3 3L8.5 11L3 17H4.5L9.2 12L13 17H17.5L11.5 8.5L16.5 3H15L10.8 7.5L7.5 3H3ZM5 4.5H7L15.5 15.5H13.5L5 4.5Z" fill="white"/>
        </svg>
      </a>

      <!-- LinkedIn -->
      <a
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
        class="flex h-9 w-9 items-center justify-center rounded-[12px] transition-opacity hover:opacity-80"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M4.5 3C3.67 3 3 3.67 3 4.5C3 5.33 3.67 6 4.5 6C5.33 6 6 5.33 6 4.5C6 3.67 5.33 3 4.5 3ZM3 8H6V17H3V8ZM8 8H11V9.3C11.5 8.5 12.6 7.7 14.2 7.7C16.8 7.7 17 9.5 17 11.5V17H14V12C14 10.8 13.8 9.8 12.5 9.8C11.2 9.8 11 10.7 11 11.9V17H8V8Z" fill="white"/>
        </svg>
      </a>
    </div>

    <!-- Text Block -->
    <div class="flex flex-col items-center gap-4">
      <!-- Legal Links -->
      <div class="flex flex-wrap items-center justify-center gap-6">
        <a
          href="/privacy"
          class="font-body text-sm leading-5 tracking-[-0.15px] text-[rgba(250,248,245,0.7)] transition-opacity hover:opacity-100"
        >
          Privacy Policy
        </a>
        <a
          href="/terms"
          class="font-body text-sm leading-5 tracking-[-0.15px] text-[rgba(250,248,245,0.7)] transition-opacity hover:opacity-100"
        >
          Terms of Service
        </a>
        <a
          href="/nonprofit-disclosures"
          class="font-body text-sm leading-5 tracking-[-0.15px] text-[rgba(250,248,245,0.7)] transition-opacity hover:opacity-100"
        >
          Nonprofit Disclosures
        </a>
      </div>

      <!-- Copyright -->
      <p class="text-center font-body text-sm leading-5 text-[rgba(250,248,245,0.7)]">
        &copy; 2026 Jewmanity. A registered 501(c)(3) nonprofit organization. EIN: 12-3456789
      </p>

      <!-- Disclaimer -->
      <p class="text-center font-body text-xs leading-4 text-[rgba(250,248,245,0.6)]">
        All donations are tax-deductible to the fullest extent allowed by law.
      </p>
    </div>
  </div>
</footer>
