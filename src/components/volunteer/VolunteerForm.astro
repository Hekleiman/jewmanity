---
interface Props {
  heading?: string;
  subtitle?: string;
  privacyNote?: string;
}

const { heading, subtitle, privacyNote } = Astro.props;
const displayHeading = heading || 'Volunteer Application';
const displaySubtitle = subtitle || "Fill out the form below and we'll be in touch to find the right fit for you.";
const displayPrivacyNote = privacyNote || 'Your information will be kept confidential and used only for volunteer coordination.';
---

<section id="volunteer-form" class="bg-bg-alt py-16 md:py-20 lg:py-24">
  <div class="mx-auto max-w-[700px] px-6">
    <h2 class="text-center font-heading text-[clamp(28px,4vw,36px)] font-medium leading-tight text-text-heading">
      {displayHeading}
    </h2>
    <p class="mx-auto mt-4 max-w-[550px] text-center font-heading text-[clamp(16px,2.2vw,20px)] font-normal leading-relaxed text-text-body">
      {displaySubtitle}
    </p>

    <form
      id="volunteer-form-el"
      action="https://formspree.io/f/xlgpvpja"
      method="POST"
      class="mt-10 space-y-6"
    >
      <input type="hidden" name="_subject" value="New Volunteer Application" />
      <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />

      <!-- Row 1: Name -->
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        <div>
          <label for="vol-firstName" class="mb-1.5 block font-body text-sm font-medium text-text-heading">
            First Name <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="vol-firstName"
            name="firstName"
            required
            aria-required="true"
            placeholder="Enter your first name"
            class="w-full rounded-lg border border-[#DADADA] bg-white px-4 py-3 font-body text-sm text-text-heading placeholder:text-text-muted focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
          />
        </div>
        <div>
          <label for="vol-lastName" class="mb-1.5 block font-body text-sm font-medium text-text-heading">
            Last Name <span class="text-red-500">*</span>
          </label>
          <input
            type="text"
            id="vol-lastName"
            name="lastName"
            required
            aria-required="true"
            placeholder="Enter your last name"
            class="w-full rounded-lg border border-[#DADADA] bg-white px-4 py-3 font-body text-sm text-text-heading placeholder:text-text-muted focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
          />
        </div>
      </div>

      <!-- Row 2: Email + Phone -->
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        <div>
          <label for="vol-email" class="mb-1.5 block font-body text-sm font-medium text-text-heading">
            Email Address <span class="text-red-500">*</span>
          </label>
          <input
            type="email"
            id="vol-email"
            name="email"
            required
            aria-required="true"
            placeholder="your@email.com"
            class="w-full rounded-lg border border-[#DADADA] bg-white px-4 py-3 font-body text-sm text-text-heading placeholder:text-text-muted focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
          />
        </div>
        <div>
          <label for="vol-phone" class="mb-1.5 block font-body text-sm font-medium text-text-heading">
            Phone Number
          </label>
          <input
            type="tel"
            id="vol-phone"
            name="phone"
            placeholder="(555) 123-4567"
            class="w-full rounded-lg border border-[#DADADA] bg-white px-4 py-3 font-body text-sm text-text-heading placeholder:text-text-muted focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
          />
        </div>
      </div>

      <!-- Row 3: Location + How did you hear -->
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        <div>
          <label for="vol-location" class="mb-1.5 block font-body text-sm font-medium text-text-heading">
            City / Location
          </label>
          <input
            type="text"
            id="vol-location"
            name="location"
            placeholder="e.g. San Diego, CA"
            class="w-full rounded-lg border border-[#DADADA] bg-white px-4 py-3 font-body text-sm text-text-heading placeholder:text-text-muted focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
          />
        </div>
        <div>
          <label for="vol-referral" class="mb-1.5 block font-body text-sm font-medium text-text-heading">
            How did you hear about us?
          </label>
          <select
            id="vol-referral"
            name="referral"
            class="w-full appearance-none rounded-lg border border-[#DADADA] bg-white px-4 py-3 font-body text-sm text-text-heading focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
          >
            <option value="" disabled selected>Select an option</option>
            <option value="Social Media">Social Media</option>
            <option value="Friend or Family">Friend or Family</option>
            <option value="Synagogue or Community Org">Synagogue or Community Org</option>
            <option value="Web Search">Web Search</option>
            <option value="Event">Event</option>
            <option value="Other">Other</option>
          </select>
        </div>
      </div>

      <!-- Row 4: Areas of Interest -->
      <fieldset>
        <legend class="mb-3 font-body text-sm font-medium text-text-heading">
          Areas of Interest
        </legend>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
          {[
            'Preparing and Serving Meals',
            'Transportation and Logistics',
            'Hosting Dinners and Gatherings',
            'Day-to-Day Support',
            'Other',
          ].map((interest) => (
            <label class="flex cursor-pointer items-center gap-3 rounded-lg border border-[#DADADA] bg-white px-4 py-3 transition-colors has-[:checked]:border-primary has-[:checked]:bg-primary/5">
              <input
                type="checkbox"
                name="interests"
                value={interest}
                class="h-4 w-4 shrink-0 rounded border-[#DADADA] accent-primary"
              />
              <span class="font-body text-sm text-text-heading">{interest}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <!-- Row 5: About yourself -->
      <div>
        <label for="vol-about" class="mb-1.5 block font-body text-sm font-medium text-text-heading">
          Tell us about yourself
        </label>
        <textarea
          id="vol-about"
          name="about"
          rows="4"
          placeholder="Share anything you'd like us to know — your background, availability, or what drew you to volunteer."
          class="w-full resize-vertical rounded-lg border border-[#DADADA] bg-white px-4 py-3 font-body text-sm text-text-heading placeholder:text-text-muted focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
        ></textarea>
      </div>

      <!-- Row 6: Availability -->
      <div>
        <label for="vol-availability" class="mb-1.5 block font-body text-sm font-medium text-text-heading">
          Availability
        </label>
        <select
          id="vol-availability"
          name="availability"
          class="w-full appearance-none rounded-lg border border-[#DADADA] bg-white px-4 py-3 font-body text-sm text-text-heading focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
        >
          <option value="" disabled selected>Select your availability</option>
          <option value="A few hours per retreat">A few hours per retreat</option>
          <option value="Full retreat (5-7 days)">Full retreat (5-7 days)</option>
          <option value="Ongoing/regular basis">Ongoing/regular basis</option>
          <option value="Flexible">Flexible — tell me what's needed</option>
        </select>
      </div>

      <!-- Submit -->
      <div class="text-center">
        <button
          type="submit"
          id="volunteer-submit-btn"
          class="inline-block rounded-[100px] bg-primary px-8 py-3 font-heading text-sm font-medium leading-6 text-white transition-colors hover:bg-primary-hover disabled:cursor-not-allowed disabled:opacity-60"
        >
          Submit Volunteer Application
        </button>
      </div>

      <p class="text-center font-body text-sm text-text-muted">
        {displayPrivacyNote}
      </p>

      <!-- Success message -->
      <div
        id="volunteer-success"
        class="hidden rounded-lg border border-green-200 bg-green-50 p-4 text-center font-body text-sm text-green-800"
        role="alert"
      >
        Thank you for your application! We'll be in touch soon.
      </div>

      <!-- Error message -->
      <div
        id="volunteer-error"
        class="hidden rounded-lg border border-red-200 bg-red-50 p-4 text-center font-body text-sm text-red-800"
        role="alert"
      >
        Something went wrong. Please try again.
      </div>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('volunteer-form-el') as HTMLFormElement;
  const submitBtn = document.getElementById('volunteer-submit-btn') as HTMLButtonElement;
  const successMsg = document.getElementById('volunteer-success') as HTMLDivElement;
  const errorMsg = document.getElementById('volunteer-error') as HTMLDivElement;

  form.addEventListener('submit', async (e: Event) => {
    e.preventDefault();

    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';
    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (response.ok) {
        successMsg.classList.remove('hidden');
        form.reset();
      } else {
        errorMsg.classList.remove('hidden');
      }
    } catch {
      errorMsg.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit Volunteer Application';
    }
  });
</script>
