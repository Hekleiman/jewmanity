---
interface Props {
  heading?: string;
  paragraphs?: string[];
  imageUrl?: string;
}

const fallbackParagraphs: string[] = [
  "Volunteers are the heart of Jewmanity's retreats. Your presence creates a safe, welcoming space where participants can begin their healing journey from trauma, antisemitism, and the profound impacts of war.",
  "You don't need to be a therapist or trauma expert. What matters most is your compassion, reliability, and willingness to show up with care and humanity.",
  'Through simple acts\u2014preparing meals, offering rides, hosting gatherings, or providing day-to-day support\u2014you help create an environment where healing can happen.',
];

const { heading, paragraphs, imageUrl } = Astro.props;
const displayHeading = heading || 'Why Volunteer?';
const displayParagraphs = paragraphs && paragraphs.length > 0 ? paragraphs : fallbackParagraphs;
const displayImage = imageUrl || '/images/sections/volunteer-why.jpg';
---

<section id="why-volunteer" class="py-16 md:py-20 lg:py-24">
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="flex flex-col items-center gap-10 lg:flex-row lg:gap-16">
      <!-- Text -->
      <div class="lg:w-[55%]" data-animate="slide-left">
        <h2 class="font-heading text-[clamp(24px,3.5vw,32px)] font-medium leading-tight text-text-heading">
          {displayHeading}
        </h2>
        <div class="mt-6 space-y-5">
          {displayParagraphs.map((p) => (
            <p class="font-body text-[15px] leading-relaxed text-text-body md:text-base">{p}</p>
          ))}
        </div>
      </div>

      <!-- Image -->
      <div class="lg:w-[45%]" data-animate="slide-right">
        <img src={displayImage} alt="Volunteers in conversation with participants" class="aspect-[4/3] w-full rounded-2xl object-cover" width="600" height="400" loading="lazy" />
      </div>
    </div>
  </div>
</section>
