---
interface Props {
  heading?: string;
  privacyNote?: string;
}

const { heading, privacyNote } = Astro.props;
const displayHeading = heading || 'Contact Us';
const displayPrivacyNote = privacyNote || 'Your message will be kept private and treated with care.';
---

<section id="contact-form" class="py-16 md:py-20 lg:py-24">
  <div class="mx-auto max-w-[700px] px-6">
    <h2 class="text-center font-heading text-[clamp(28px,4vw,36px)] font-medium leading-tight text-text-heading">
      {displayHeading}
    </h2>

    <form
      id="contact-form-el"
      action="https://formspree.io/f/xlgpvpja"
      method="POST"
      class="mt-10 space-y-6"
    >

      <!-- Honeypot spam field -->
      <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        <div>
          <label for="firstName" class="mb-1.5 block font-body text-sm font-medium text-text-heading">
            First Name
          </label>
          <input
            type="text"
            id="firstName"
            name="firstName"
            required
            aria-required="true"
            placeholder="Enter your first name"
            class="w-full rounded-lg border border-[#DADADA] bg-white px-4 py-3 font-body text-sm text-text-heading placeholder:text-text-muted focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
          />
        </div>
        <div>
          <label for="lastName" class="mb-1.5 block font-body text-sm font-medium text-text-heading">
            Last Name
          </label>
          <input
            type="text"
            id="lastName"
            name="lastName"
            required
            aria-required="true"
            placeholder="Enter your last name"
            class="w-full rounded-lg border border-[#DADADA] bg-white px-4 py-3 font-body text-sm text-text-heading placeholder:text-text-muted focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
          />
        </div>
      </div>

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        <div>
          <label for="email" class="mb-1.5 block font-body text-sm font-medium text-text-heading">
            Email Address
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            aria-required="true"
            placeholder="your@email.com"
            class="w-full rounded-lg border border-[#DADADA] bg-white px-4 py-3 font-body text-sm text-text-heading placeholder:text-text-muted focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
          />
        </div>
        <div>
          <label for="subject" class="mb-1.5 block font-body text-sm font-medium text-text-heading">
            Subject
          </label>
          <select
            id="subject"
            name="subject"
            required
            aria-required="true"
            class="w-full appearance-none rounded-lg border border-[#DADADA] bg-white px-4 py-3 font-body text-sm text-text-heading focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
          >
            <option value="" disabled selected>Select a topic</option>
            <option value="General Inquiry">General Inquiry</option>
            <option value="Program Information">Program Information</option>
            <option value="Volunteer Opportunities">Volunteer Opportunities</option>
            <option value="Donation Questions">Donation Questions</option>
            <option value="Partnership">Partnership</option>
            <option value="Other">Other</option>
          </select>
        </div>
      </div>

      <div>
        <label for="message" class="mb-1.5 block font-body text-sm font-medium text-text-heading">
          Message
        </label>
        <textarea
          id="message"
          name="message"
          required
          aria-required="true"
          rows="5"
          placeholder="Write your message here..."
          class="w-full resize-vertical rounded-lg border border-[#DADADA] bg-white px-4 py-3 font-body text-sm text-text-heading placeholder:text-text-muted focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
        ></textarea>
      </div>

      <div class="text-center">
        <button
          type="submit"
          id="contact-submit-btn"
          class="inline-block rounded-[100px] bg-primary px-8 py-3 font-heading text-sm font-medium leading-6 text-white transition-colors hover:bg-primary-hover disabled:cursor-not-allowed disabled:opacity-60"
        >
          Send Message
        </button>
      </div>

      <p class="text-center font-body text-sm text-text-muted">
        {displayPrivacyNote}
      </p>

      <!-- Success message -->
      <div
        id="contact-success"
        class="hidden rounded-lg bg-green-50 border border-green-200 p-4 text-center font-body text-sm text-green-800"
        role="alert"
      >
        Thank you! Your message has been sent.
      </div>

      <!-- Error message -->
      <div
        id="contact-error"
        class="hidden rounded-lg bg-red-50 border border-red-200 p-4 text-center font-body text-sm text-red-800"
        role="alert"
      >
        Something went wrong. Please try again.
      </div>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form-el') as HTMLFormElement;
  const submitBtn = document.getElementById('contact-submit-btn') as HTMLButtonElement;
  const successMsg = document.getElementById('contact-success') as HTMLDivElement;
  const errorMsg = document.getElementById('contact-error') as HTMLDivElement;

  form.addEventListener('submit', async (e: Event) => {
    e.preventDefault();

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';
    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (response.ok) {
        successMsg.classList.remove('hidden');
        form.reset();
      } else {
        errorMsg.classList.remove('hidden');
      }
    } catch {
      errorMsg.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send Message';
    }
  });
</script>
