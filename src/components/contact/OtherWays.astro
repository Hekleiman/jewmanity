---
interface ConnectCard {
  icon?: string;
  title?: string;
  description?: string;
  linkText?: string;
  href?: string;
}

interface Props {
  heading?: string;
  cards?: ConnectCard[];
}

const fallbackCards: ConnectCard[] = [
  { icon: 'people', title: 'Get Involved', description: 'Join our community and engage in fostering healing and connection.', linkText: 'Learn More', href: '/get-involved/volunteer' },
  { icon: 'book', title: 'Resources', description: 'Access helpful materials, guides, and information for your journey.', linkText: 'Learn More', href: '/resources' },
  { icon: 'heart', title: 'Support Healing', description: 'Make a difference by supporting our mission of healing and resilience.', linkText: 'Learn More', href: '/donate' },
];

const KNOWN_ICONS = new Set(['people', 'book', 'heart']);

const { heading, cards } = Astro.props;
const displayHeading = heading || 'Other Ways to Connect';
const displayCards = cards && cards.length > 0 ? cards : fallbackCards;
---

<section id="other-ways" class="bg-bg-section-alt py-16 md:py-20 lg:py-24">
  <div class="mx-auto max-w-[1200px] px-6">
    <h2 class="mb-12 text-center font-heading text-[clamp(28px,4vw,36px)] font-medium leading-tight text-text-heading">
      {displayHeading}
    </h2>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-3">
      {displayCards.map((card) => (
        <article class="flex flex-col items-center rounded-[24px] border-[0.5px] border-border-card bg-white p-8 text-center shadow-[0px_16px_32px_rgba(12,12,13,0.1),0px_4px_4px_rgba(12,12,13,0.05)]">
          <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-primary-light">
            {card.icon === 'people' && (
              <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
              </svg>
            )}
            {card.icon === 'book' && (
              <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
              </svg>
            )}
            {card.icon === 'heart' && (
              <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
              </svg>
            )}
            {(!card.icon || !KNOWN_ICONS.has(card.icon)) && (
              <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <circle cx="12" cy="12" r="8" stroke="currentColor"/>
              </svg>
            )}
          </div>
          <h3 class="mb-2 font-body text-lg font-medium text-text-heading">
            {card.title}
          </h3>
          <p class="mb-4 font-body text-sm leading-6 text-text-body">
            {card.description}
          </p>
          {card.href && (
            <a
              href={card.href}
              class="mt-auto inline-flex items-center gap-1 font-body text-sm font-medium text-primary transition-colors hover:text-primary-hover"
            >
              {card.linkText || 'Learn More'}
              <span aria-hidden="true">&rarr;</span>
            </a>
          )}
        </article>
      ))}
    </div>
  </div>
</section>
