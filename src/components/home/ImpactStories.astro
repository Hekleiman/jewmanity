---
interface Props {}
---

<section id="impact-stories" class="bg-bg-section-alt py-16 md:py-20 lg:py-24">
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="mb-12 text-center" data-animate="fade-up">
      <h2 class="font-heading text-[clamp(28px,4vw,36px)] font-medium leading-tight text-text-heading">
        Impact Stories
      </h2>
      <p class="mx-auto mt-4 max-w-[600px] font-heading text-[clamp(18px,2.5vw,24px)] font-normal leading-relaxed text-text-body">
        Real stories from individuals supported through Jewmanity's programs and community.
      </p>
    </div>

    <article data-animate="fade-in" class="overflow-hidden rounded-[24px] border-[0.5px] border-border-card bg-white shadow-[0px_16px_32px_rgba(12,12,13,0.1),0px_4px_4px_rgba(12,12,13,0.05)]">
      <div class="flex flex-col md:flex-row">
        <div class="h-64 md:h-auto md:w-[40%]">
          <img src="/images/sections/impact-story.jpg" alt="Community support and healing through Jewmanity programs" class="h-full w-full object-cover" width="600" height="400" loading="lazy" />
        </div>

        <div class="flex flex-col justify-center p-6 md:w-[60%] md:p-10">
          <span class="font-body text-xs font-medium uppercase tracking-widest text-primary">
            Community Story
          </span>
          <h3 class="mt-3 font-body text-xl font-medium leading-7 text-text-heading">
            Finding strength through community
          </h3>
          <blockquote class="mt-4 space-y-4">
            <p class="font-body text-sm italic leading-6 text-text-body">
              "After experiencing the trauma of antisemitic violence, I felt completely isolated.
              Jewmanity's peer support program helped me understand that I wasn't alone in what I
              was going through."
            </p>
            <p class="font-body text-sm italic leading-6 text-text-body">
              "The retreat gave me tools to process my PTSD symptoms in a safe environment. For
              the first time in months, I felt seen, heard, and motivated about healing."
            </p>
          </blockquote>
          <p class="mt-6 font-body text-sm font-medium text-text-heading">
            &mdash; Sarah M., Program Participant
          </p>
        </div>
      </div>
    </article>

    <!-- Dot navigation (static — carousel behavior added in Phase 3A) -->
    <div class="mt-8 flex items-center justify-center gap-3" aria-label="Testimonial navigation">
      <button class="h-2.5 w-2.5 rounded-full bg-primary" aria-current="true" aria-label="Story 1"></button>
      <button class="h-2.5 w-2.5 rounded-full bg-gray-300" aria-label="Story 2"></button>
      <button class="h-2.5 w-2.5 rounded-full bg-gray-300" aria-label="Story 3"></button>
      <button class="h-2.5 w-2.5 rounded-full bg-gray-300" aria-label="Story 4"></button>
    </div>
  </div>
</section>
