---
interface Props {}

const testimonials = [
  {
    quote: "After experiencing the trauma of antisemitic violence, I felt completely isolated. Jewmanity's peer support program helped me understand that I wasn't alone in what I was going through.",
    author: "Sarah M.",
    context: "Program Participant",
  },
  {
    quote: "The retreat gave me tools to process my PTSD symptoms in a safe environment. For the first time in months, I felt seen, heard, and hopeful about healing.",
    author: "David R.",
    context: "Retreat Participant",
  },
  {
    quote: "Jewmanity didn't just offer support — they offered community. Knowing others understood my experience made all the difference in my recovery.",
    author: "Rachel K.",
    context: "Community Member",
  },
  {
    quote: "The compassion and dedication of the Jewmanity team gave our family hope during the darkest time of our lives. We are forever grateful.",
    author: "Michael & Leah T.",
    context: "Family Program",
  },
];
---

<section id="impact-stories" class="bg-bg-section-alt py-16 md:py-20 lg:py-24">
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="mb-12 text-center" data-animate="fade-up">
      <h2 class="font-heading text-[clamp(28px,4vw,36px)] font-medium leading-tight text-text-heading">
        Impact Stories
      </h2>
      <p class="mx-auto mt-4 max-w-[600px] font-heading text-[clamp(18px,2.5vw,24px)] font-normal leading-relaxed text-text-body">
        Real stories from individuals supported through Jewmanity's programs and community.
      </p>
    </div>

    <article
      id="impact-carousel"
      data-animate="fade-in"
      class="overflow-hidden rounded-[24px] border-[0.5px] border-border-card bg-white shadow-[0px_16px_32px_rgba(12,12,13,0.1),0px_4px_4px_rgba(12,12,13,0.05)]"
    >
      <div class="flex flex-col md:flex-row">
        <div class="h-64 md:h-auto md:w-[40%]">
          <img src="/images/sections/impact-story.jpg" alt="Community support and healing through Jewmanity programs" class="h-full w-full object-cover" width="600" height="400" loading="lazy" />
        </div>

        <div class="relative flex flex-col justify-center p-6 md:w-[60%] md:p-10">
          <span class="font-body text-xs font-medium uppercase tracking-widest text-primary">
            Community Story
          </span>
          <h3 class="mt-3 font-body text-xl font-medium leading-7 text-text-heading">
            Finding strength through community
          </h3>

          <div id="impact-slides" class="relative mt-4 min-h-[140px]">
            {testimonials.map((t, i) => (
              <div
                class:list={[
                  "impact-slide absolute inset-0 transition-opacity duration-500",
                  i === 0 ? "opacity-100" : "opacity-0 pointer-events-none",
                ]}
                data-index={i}
              >
                <blockquote>
                  <p class="font-body text-sm italic leading-6 text-text-body">
                    "{t.quote}"
                  </p>
                </blockquote>
                <p class="mt-6 font-body text-sm font-medium text-text-heading">
                  &mdash; {t.author}, {t.context}
                </p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </article>

    <div
      id="impact-dots"
      class="mt-8 flex items-center justify-center gap-3"
      role="tablist"
      aria-label="Testimonial navigation"
    >
      {testimonials.map((_, i) => (
        <button
          type="button"
          class:list={[
            "impact-dot h-2.5 w-2.5 rounded-full transition-colors duration-300",
            i === 0 ? "bg-primary" : "bg-gray-300",
          ]}
          role="tab"
          aria-selected={i === 0 ? "true" : "false"}
          aria-label={`Story ${i + 1}`}
          data-index={i}
        ></button>
      ))}
    </div>
  </div>
</section>

<script>
  const slides = document.querySelectorAll<HTMLElement>('.impact-slide');
  const dots = document.querySelectorAll<HTMLButtonElement>('.impact-dot');
  const carousel = document.getElementById('impact-carousel');
  const total = slides.length;
  let current = 0;
  let timer: ReturnType<typeof setInterval> | null = null;

  function goTo(index: number) {
    slides.forEach((slide, i) => {
      if (i === index) {
        slide.classList.remove('opacity-0', 'pointer-events-none');
        slide.classList.add('opacity-100');
      } else {
        slide.classList.add('opacity-0', 'pointer-events-none');
        slide.classList.remove('opacity-100');
      }
    });
    dots.forEach((dot, i) => {
      dot.classList.toggle('bg-primary', i === index);
      dot.classList.toggle('bg-gray-300', i !== index);
      dot.setAttribute('aria-selected', i === index ? 'true' : 'false');
    });
    current = index;
  }

  function next() {
    goTo((current + 1) % total);
  }

  function startAutoplay() {
    if (timer) clearInterval(timer);
    timer = setInterval(next, 6000);
  }

  function stopAutoplay() {
    if (timer) { clearInterval(timer); timer = null; }
  }

  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      const idx = Number(dot.dataset.index);
      goTo(idx);
      stopAutoplay();
      startAutoplay();
    });
  });

  carousel?.addEventListener('mouseenter', stopAutoplay);
  carousel?.addEventListener('mouseleave', startAutoplay);

  // Touch swipe support
  let touchStartX = 0;
  carousel?.addEventListener('touchstart', (e) => {
    touchStartX = (e as TouchEvent).touches[0].clientX;
    stopAutoplay();
  }, { passive: true });

  carousel?.addEventListener('touchend', (e) => {
    const diff = touchStartX - (e as TouchEvent).changedTouches[0].clientX;
    if (Math.abs(diff) > 50) {
      if (diff > 0) goTo((current + 1) % total);
      else goTo((current - 1 + total) % total);
    }
    startAutoplay();
  }, { passive: true });

  startAutoplay();
</script>
