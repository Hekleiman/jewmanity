---
import { getTestimonials, urlFor } from '../../lib/sanity';
import type { SanityImageSource } from '@sanity/image-url/lib/types/types';

interface Testimonial {
  name: string;
  role: string;
  excerpt: string;
  slug: string;
  imageUrl?: string;
  imageAlt?: string;
  link?: string;
}

interface Props {
  heading?: string;
  subtitle?: string;
}

const { heading, subtitle } = Astro.props;
const displayHeading = heading || 'Impact Stories';
const displaySubtitle = subtitle || "Real stories from individuals supported through Jewmanity's programs and community.";

// Hardcoded fallbacks with real testimonial data
const fallbackTestimonials: Testimonial[] = [
  {
    name: 'Matamba Lassan',
    role: 'Retreat Participant',
    excerpt:
      'After October 7th, I lost my faith \u2014 especially in myself. Through Jewmanity, I spent a month in the U.S. healing and being supported by professional care. This journey helped me believe in myself again.',
    slug: 'matamba-lassan',
    imageUrl: '/images/testimonials/matamba.png',
  },
  {
    name: 'Dahlia',
    role: 'Volunteer',
    excerpt:
      "I give them my heart, my time, and my presence, and somehow I receive so much back. The joy of giving to them feels endless, and I'm grateful to be part of their journey.",
    slug: 'dahlia',
    imageUrl: '/images/testimonials/dahlia.png',
  },
  {
    name: 'Your Story',
    role: 'Share your experience',
    excerpt:
      "Every person who joins our community adds to our shared strength. Your story matters, and we'd love to hear it.",
    slug: '',
    link: '/get-involved/contact',
  },
];

let testimonials: Testimonial[] = [];

try {
  const raw = await getTestimonials();
  if (raw && raw.length > 0) {
    testimonials = raw.map((t: Record<string, unknown>) => ({
      name: (t.authorName as string) || '',
      role: (t.authorRole as string) || '',
      excerpt: (t.excerpt as string) || (t.quote as string) || '',
      slug: (t.slug as string) || '',
      imageUrl: t.imageUrl
        ? (t.imageUrl as string)
        : t.authorImage
          ? urlFor(t.authorImage as SanityImageSource).width(160).height(160).url()
          : undefined,
    }));
    // Always append the "Your Story" placeholder
    testimonials.push(fallbackTestimonials[2]);
  }
} catch (e) {
  console.warn('Sanity fetch failed for testimonials, using fallback content');
}

if (testimonials.length === 0) {
  testimonials = fallbackTestimonials;
}
---

<section id="impact-stories" class="bg-bg-section-alt py-16 md:py-20 lg:py-24">
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="mb-12 text-center" data-animate="fade-up">
      <h2 class="font-heading text-[clamp(28px,4vw,36px)] font-medium leading-tight text-text-heading">
        {displayHeading}
      </h2>
      <p class="mx-auto mt-4 max-w-[600px] font-heading text-[clamp(18px,2.5vw,24px)] font-normal leading-relaxed text-text-body">
        {displaySubtitle}
      </p>
    </div>

    <div
      id="impact-carousel"
      data-animate="fade-in"
      class="mx-auto max-w-[800px]"
    >
      <div id="impact-slides" class="relative">
        {testimonials.map((t, i) => (
          <div
            class:list={[
              "impact-slide transition-opacity duration-500",
              i === 0 ? "opacity-100 relative" : "opacity-0 pointer-events-none absolute inset-0",
            ]}
            data-index={i}
          >
            <div class="flex flex-col items-center text-center gap-4 px-4">
              {/* Photo or placeholder icon */}
              {t.imageUrl ? (
                <img
                  src={t.imageUrl}
                  alt={t.name}
                  class="h-28 w-28 rounded-full object-cover"
                  width="112"
                  height="112"
                  loading="lazy"
                />
              ) : (
                <div class="flex h-28 w-28 items-center justify-center rounded-full bg-primary/10">
                  <svg class="h-10 w-10 text-primary/50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                  </svg>
                </div>
              )}

              {/* Excerpt */}
              <blockquote class="max-w-2xl font-body text-lg italic leading-relaxed text-text-body">
                &ldquo;{t.excerpt}&rdquo;
              </blockquote>

              {/* Attribution */}
              <div>
                <p class="font-body text-base font-semibold text-text-heading">{t.name}</p>
                <p class="font-body text-sm text-text-body">{t.role}</p>
              </div>

              {/* Link */}
              <a
                href={t.link || `/about/community-stories#${t.slug}`}
                class="font-body text-sm font-medium text-primary hover:underline"
              >
                {t.slug ? 'Read their story \u2192' : 'Share your story \u2192'}
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-8 flex items-center justify-center gap-6">
      <button
        id="impact-prev"
        class="flex h-8 w-8 items-center justify-center rounded-full border border-border-card text-text-muted transition-colors hover:border-primary hover:text-primary"
        aria-label="Previous story"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div
        id="impact-dots"
        class="flex items-center gap-2"
        role="tablist"
        aria-label="Testimonial navigation"
      >
        {testimonials.map((_, i) => (
          <button
            type="button"
            class:list={[
              "impact-dot h-2.5 w-2.5 rounded-full transition-colors duration-300",
              i === 0 ? "bg-primary" : "bg-gray-300",
            ]}
            role="tab"
            aria-selected={i === 0 ? "true" : "false"}
            aria-label={`Story ${i + 1}`}
            data-index={i}
          ></button>
        ))}
      </div>
      <button
        id="impact-next"
        class="flex h-8 w-8 items-center justify-center rounded-full border border-border-card text-text-muted transition-colors hover:border-primary hover:text-primary"
        aria-label="Next story"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</section>

<script>
  const slides = document.querySelectorAll<HTMLElement>('.impact-slide');
  const dots = document.querySelectorAll<HTMLButtonElement>('.impact-dot');
  const carousel = document.getElementById('impact-carousel');
  const prevBtn = document.getElementById('impact-prev');
  const nextBtn = document.getElementById('impact-next');
  const total = slides.length;
  let current = 0;
  let timer: ReturnType<typeof setInterval> | null = null;

  function goTo(index: number) {
    slides.forEach((slide, i) => {
      if (i === index) {
        slide.classList.remove('opacity-0', 'pointer-events-none', 'absolute', 'inset-0');
        slide.classList.add('opacity-100', 'relative');
      } else {
        slide.classList.add('opacity-0', 'pointer-events-none', 'absolute', 'inset-0');
        slide.classList.remove('opacity-100', 'relative');
      }
    });
    dots.forEach((dot, i) => {
      dot.classList.toggle('bg-primary', i === index);
      dot.classList.toggle('bg-gray-300', i !== index);
      dot.setAttribute('aria-selected', i === index ? 'true' : 'false');
    });
    current = index;
  }

  function next() { goTo((current + 1) % total); }
  function prev() { goTo((current - 1 + total) % total); }

  function startAutoplay() {
    if (timer) clearInterval(timer);
    timer = setInterval(next, 6000);
  }

  function stopAutoplay() {
    if (timer) { clearInterval(timer); timer = null; }
  }

  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      goTo(Number(dot.dataset.index));
      stopAutoplay();
      startAutoplay();
    });
  });

  prevBtn?.addEventListener('click', () => { prev(); stopAutoplay(); startAutoplay(); });
  nextBtn?.addEventListener('click', () => { next(); stopAutoplay(); startAutoplay(); });

  carousel?.addEventListener('mouseenter', stopAutoplay);
  carousel?.addEventListener('mouseleave', startAutoplay);

  // Touch swipe support
  let touchStartX = 0;
  carousel?.addEventListener('touchstart', (e) => {
    touchStartX = (e as TouchEvent).touches[0].clientX;
    stopAutoplay();
  }, { passive: true });

  carousel?.addEventListener('touchend', (e) => {
    const diff = touchStartX - (e as TouchEvent).changedTouches[0].clientX;
    if (Math.abs(diff) > 50) {
      if (diff > 0) goTo((current + 1) % total);
      else goTo((current - 1 + total) % total);
    }
    startAutoplay();
  }, { passive: true });

  startAutoplay();
</script>
