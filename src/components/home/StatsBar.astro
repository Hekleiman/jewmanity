---
interface Stat {
  icon?: string;
  value?: string;
  label?: string;
}

interface Props {
  stats?: Stat[];
}

const fallbackStats: Stat[] = [
  { icon: 'shield', value: '501(c)(3) Nonprofit', label: 'Tax-exempt charitable organization' },
  { icon: 'calendar', value: 'Established 2019', label: 'Years of dedicated service' },
  { icon: 'people', value: '1,500+ Helped', label: 'Individuals across all programs' },
  { icon: 'heart', value: '4 Core Programs', label: 'Comprehensive healing services' },
];

const KNOWN_ICONS = new Set(['shield', 'calendar', 'people', 'heart']);

const { stats } = Astro.props;
const displayStats = stats && stats.length > 0 ? stats : fallbackStats;
---

<section id="stats" class="py-14 md:py-16 lg:py-20">
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="grid grid-cols-2 gap-8 lg:grid-cols-4" data-animate="stagger">
      {displayStats.map((stat) => (
        <div class="flex flex-col items-center text-center">
          <div class="mb-3 text-primary">
            {stat.icon === 'shield' && (
              <svg width="36" height="36" viewBox="0 0 36 36" fill="none" aria-hidden="true">
                <path d="M18 3L5 9v9c0 8.4 5.54 16.24 13 18 7.46-1.76 13-9.6 13-18V9L18 3z" stroke="currentColor" stroke-width="2" fill="none"/>
                <path d="M13 18l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
            {stat.icon === 'calendar' && (
              <svg width="36" height="36" viewBox="0 0 36 36" fill="none" aria-hidden="true">
                <rect x="5" y="8" width="26" height="23" rx="3" stroke="currentColor" stroke-width="2" fill="none"/>
                <path d="M5 15h26" stroke="currentColor" stroke-width="2"/>
                <path d="M12 5v6M24 5v6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <rect x="10" y="19" width="4" height="4" rx="1" fill="currentColor"/>
                <rect x="16" y="19" width="4" height="4" rx="1" fill="currentColor"/>
                <rect x="22" y="19" width="4" height="4" rx="1" fill="currentColor"/>
              </svg>
            )}
            {stat.icon === 'people' && (
              <svg width="36" height="36" viewBox="0 0 36 36" fill="none" aria-hidden="true">
                <circle cx="18" cy="11" r="4" stroke="currentColor" stroke-width="2" fill="none"/>
                <path d="M10 28c0-4.42 3.58-8 8-8s8 3.58 8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" fill="none"/>
                <circle cx="27" cy="13" r="3" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <path d="M28 28c2.76-1.5 4-4.5 4-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none"/>
                <circle cx="9" cy="13" r="3" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <path d="M8 28c-2.76-1.5-4-4.5-4-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" fill="none"/>
              </svg>
            )}
            {stat.icon === 'heart' && (
              <svg width="36" height="36" viewBox="0 0 36 36" fill="none" aria-hidden="true">
                <path d="M18 30s-10-6.5-10-14a6.5 6.5 0 0113 0 6.5 6.5 0 0113 0c0 7.5-10 14-10 14h-6z" stroke="currentColor" stroke-width="2" fill="none"/>
                <path d="M18 30s-10-6.5-10-14a6.5 6.5 0 0113 0" stroke="currentColor" stroke-width="2" fill="none"/>
              </svg>
            )}
            {(!stat.icon || !KNOWN_ICONS.has(stat.icon)) && (
              <svg width="36" height="36" viewBox="0 0 36 36" fill="none" aria-hidden="true">
                <circle cx="18" cy="18" r="12" stroke="currentColor" stroke-width="2" fill="none"/>
              </svg>
            )}
          </div>
          <p class="font-heading text-base font-medium text-text-heading md:text-lg">
            {stat.value}
          </p>
          <p class="mt-1 font-body text-xs text-text-body md:text-[13px]">
            {stat.label}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
