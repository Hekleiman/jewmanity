---
interface Props {}

interface IncludedItem {
  icon: string;
  title: string;
  description: string;
}

const items: IncludedItem[] = [
  {
    icon: 'therapy',
    title: 'Daily Therapy Sessions',
    description: 'Individual and group therapy with certified trauma counselors',
  },
  {
    icon: 'accommodation',
    title: 'Comfortable Accommodations',
    description: 'Private rooms in peaceful, comfortable shared settings',
  },
  {
    icon: 'meals',
    title: 'All Meals Provided',
    description: 'Full-time, culturally appropriate meals prepared with care',
  },
  {
    icon: 'transport',
    title: 'Transportation',
    description: 'Airport pickup and all transportation during the retreat',
  },
  {
    icon: 'activities',
    title: 'Recreational Activities',
    description: 'Healing excursions, nature walks, and community experiences',
  },
  {
    icon: 'support',
    title: 'Ongoing Support',
    description: 'Post-retreat resources and connection to continuing care',
  },
];
---

<section id="whats-included" class="py-16 md:py-20 lg:py-24">
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="mb-12 text-center" data-animate="fade-up">
      <h2 class="font-heading text-[clamp(28px,4vw,36px)] font-medium leading-tight text-text-heading">
        What's Included
      </h2>
      <p class="mx-auto mt-4 max-w-[600px] font-body text-[15px] leading-relaxed text-text-body md:text-base">
        Everything participants need to focus on their healing journey
      </p>
    </div>

    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3" data-animate="stagger">
      {items.map((item) => (
        <div class="flex gap-4 rounded-2xl border-[0.5px] border-border-card bg-white p-5 shadow-[0px_4px_12px_rgba(12,12,13,0.04),0px_2px_4px_rgba(12,12,13,0.03)]">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-primary-light text-primary">
            {item.icon === 'therapy' && (
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M10 2a6 6 0 00-6 6v2a6 6 0 0012 0V8a6 6 0 00-6-6z" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <path d="M7 10h6M10 7v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            )}
            {item.icon === 'accommodation' && (
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M3 17V9l7-5 7 5v8a1 1 0 01-1 1H4a1 1 0 01-1-1z" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <path d="M8 18v-5h4v5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            )}
            {item.icon === 'meals' && (
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M3 10h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M4 10c0-3 2.7-6 6-6s6 3 6 6" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <path d="M5 13h10a1 1 0 010 2H5a1 1 0 010-2z" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <path d="M8 15v2m4-2v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            )}
            {item.icon === 'transport' && (
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <rect x="2" y="7" width="16" height="8" rx="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <circle cx="6" cy="15" r="1.5" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <circle cx="14" cy="15" r="1.5" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <path d="M2 11h16" stroke="currentColor" stroke-width="1.5"/>
                <path d="M5 7V5h4v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            )}
            {item.icon === 'activities' && (
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M3 17l4-6 3 4 2-3 5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="14" cy="5" r="2" stroke="currentColor" stroke-width="1.5" fill="none"/>
              </svg>
            )}
            {item.icon === 'support' && (
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <circle cx="10" cy="10" r="7" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <circle cx="10" cy="10" r="3" stroke="currentColor" stroke-width="1.5" fill="none"/>
                <path d="M10 3v4m0 6v4M3 10h4m6 0h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            )}
          </div>
          <div>
            <h3 class="font-body text-[15px] font-medium text-text-heading">
              {item.title}
            </h3>
            <p class="mt-1 font-body text-sm leading-relaxed text-text-body">
              {item.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
