---
import RetreatCard from './RetreatCard.astro';

interface Retreat {
  title: string;
  location: string;
  description: string;
  href: string;
  image?: string;
}

interface Props {
  retreats?: Retreat[];
}

const fallbackRetreats: Retreat[] = [
  {
    title: 'Heads Up Retreat #4 \u2014 Fathers, Fighters',
    location: 'Del Mar, California \u00B7 December 2025',
    description: 'Older soldiers \u2014 all fathers, all veterans of decades of service \u2014 arrived for 10 days of therapy, surf therapy, and brotherhood.',
    href: '/programs/heads-up-retreat-4-fathers-fighters',
    image: '/images/retreats/retreat-4.jpg',
  },
  {
    title: 'Heads Up Retreat #3 \u2014 The Brave Girls',
    location: 'Del Mar, California \u00B7 July 2025',
    description: 'Nine female IDF soldiers from Kissufim and Nahal Oz arrived for the first all-female Heads Up retreat \u2014 yoga, surf therapy, equine therapy, and sisterhood.',
    href: '/programs/heads-up-third-retreat',
    image: '/images/retreats/retreat-3.jpg',
  },
  {
    title: 'Heads Up Retreat #2 \u2014 Golani Boys',
    location: 'Del Mar, California \u00B7 January 2025',
    description: 'Nine soldiers from the Golani Battalion arrived in San Diego for ten days of healing \u2014 therapy, surf therapy with dolphins, and art therapy at the Museum of Tolerance.',
    href: '/programs/heads-up-second-retreat',
    image: '/images/retreats/retreat-2.jpg',
  },
  {
    title: 'Heads Up First Retreat',
    location: 'Del Mar, California \u00B7 June 2024',
    description: 'The story of how Jewmanity\u2019s healing retreat program began \u2014 bringing Golani Battalion soldiers to San Diego for 10 days of therapy, community, and hope.',
    href: '/programs/heads-up-first-retreat',
    image: '/images/retreats/retreat-1.jpg',
  },
];

const { retreats: cmsRetreats } = Astro.props;
const retreats = cmsRetreats && cmsRetreats.length > 0 ? cmsRetreats : fallbackRetreats;
---

<section id="retreat-grid" class="py-16 md:py-20 lg:py-24">
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="mb-12 text-center">
      <h2 class="font-heading text-[clamp(28px,4vw,36px)] font-medium leading-tight text-text-heading">
        Stories of courage, connection, and healing
      </h2>
      <p class="mx-auto mt-4 max-w-[800px] font-body text-[15px] leading-relaxed text-text-body md:text-base">
        These retreats are part of the Heads Up &times; Jewmanity collaboration, a comprehensive program designed to support Israeli soldiers and their loved ones experiencing PTSD and ongoing trauma. Through shared experiences in nature and community, participants find healing, build lasting connections, and create a foundation for long-term recovery and growth.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      {retreats.map((retreat) => (
        <RetreatCard
          title={retreat.title}
          location={retreat.location}
          description={retreat.description}
          href={retreat.href}
          image={retreat.image}
        />
      ))}
    </div>
  </div>
</section>
