---
interface Props {}

interface Stat {
  value: string;
  label: string;
}

const stats: Stat[] = [
  { value: '12', label: 'Retreats Completed' },
  { value: '180+', label: 'Participants Supported' },
  { value: '100%', label: 'Scholarship Coverage' },
];
---

<section id="impact-stats" class="bg-bg-section-alt py-16 md:py-20 lg:py-24">
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="mb-12 text-center" data-animate="fade-up">
      <h2 class="font-heading text-[clamp(28px,4vw,36px)] font-medium leading-tight text-text-heading">
        Our Growing Impact
      </h2>
      <p class="mx-auto mt-4 max-w-[600px] font-body text-[15px] leading-relaxed text-text-body md:text-base">
        Since our founding, we've remained committed to expanding access to healing.
      </p>
    </div>

    <div class="grid grid-cols-1 gap-8 sm:grid-cols-3">
      {stats.map((stat) => (
        <div class="text-center">
          <p data-animate="counter" class="font-heading text-[clamp(40px,6vw,56px)] font-medium leading-none text-primary">
            {stat.value}
          </p>
          <p class="mt-3 font-body text-sm text-text-body md:text-base">
            {stat.label}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
