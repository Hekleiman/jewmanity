---
interface Props {}

interface NavItem {
  label: string;
  href: string;
  children?: { label: string; href: string }[];
}

const navItems: NavItem[] = [
  { label: 'Home', href: '/' },
  {
    label: 'About',
    href: '/about/story',
    children: [
      { label: 'Our Story', href: '/about/story' },
      { label: 'Our Team', href: '/about/team' },
    ],
  },
  {
    label: 'Programs',
    href: '/programs/heads-up',
    children: [
      { label: 'Heads Up', href: '/programs/heads-up' },
      { label: 'Past Retreats', href: '/programs/past-retreats' },
    ],
  },
  {
    label: 'Community',
    href: '/community/fighting-antisemitism',
    children: [
      { label: 'Community Stories', href: '/about/community-stories' },
      { label: 'Fighting Antisemitism', href: '/community/fighting-antisemitism' },
      { label: 'Recipes', href: '/community/recipes' },
    ],
  },
  {
    label: 'Get Involved',
    href: '/get-involved/volunteer',
    children: [
      { label: 'Volunteer', href: '/get-involved/volunteer' },
      { label: 'Mitzvah Project', href: '/get-involved/mitzvah-project' },
      { label: 'Contact', href: '/get-involved/contact' },
    ],
  },
  { label: 'Resources', href: '/resources' },
  { label: 'Shop', href: '/shop' },
];

const currentPath = Astro.url.pathname;

function isActive(item: NavItem): boolean {
  if (currentPath === item.href || currentPath === item.href + '/') return true;
  if (item.children) {
    return item.children.some(
      (child) => currentPath === child.href || currentPath === child.href + '/'
    );
  }
  return false;
}
---

<nav
  id="desktop-nav"
  aria-label="Main navigation"
  class="fixed top-0 left-0 right-0 z-50 hidden bg-bg-page lg:block"
>
  <div class="mx-auto flex w-full max-w-7xl items-center justify-between px-6 py-4">
    <!-- Logo -->
    <a
      href="/"
      aria-label="Jewmanity home"
      class="shrink-0 rounded-full focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary"
    >
      <img src="/images/logo.png" alt="Jewmanity" width="50" height="33" class="h-8 w-auto" />
    </a>

    <!-- Nav Links (centered group) -->
    <ul class="flex items-center gap-8">
      {navItems.map((item) => {
        const active = isActive(item);
        return (
          <li class="relative" data-dropdown={item.children ? 'true' : undefined}>
            <a
              href={item.href}
              aria-current={active ? 'page' : undefined}
              aria-haspopup={item.children ? 'true' : undefined}
              aria-expanded={item.children ? 'false' : undefined}
              class:list={[
                'inline-flex items-center gap-1 font-heading text-base font-medium leading-6 tracking-[-0.31px] transition-colors',
                'rounded-sm focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary',
                active
                  ? 'text-primary'
                  : 'text-text-heading hover:text-primary',
              ]}
            >
              {item.label}
              {item.children && (
                <svg
                  class="h-3.5 w-3.5 transition-transform duration-200"
                  viewBox="0 0 16 16"
                  fill="none"
                  aria-hidden="true"
                >
                  <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              )}
            </a>
            {item.children && (
              <ul
                class="pointer-events-none invisible absolute left-0 top-full min-w-50 pt-2 opacity-0 transition-all duration-200"
                role="menu"
              >
                <div class="rounded-xl bg-white py-2 shadow-lg">
                  {item.children.map((child) => {
                    const childActive = currentPath === child.href || currentPath === child.href + '/';
                    return (
                      <li role="none">
                        <a
                          href={child.href}
                          role="menuitem"
                          aria-current={childActive ? 'page' : undefined}
                          class:list={[
                            'block px-4 py-2 font-body text-sm transition-colors hover:bg-gray-50',
                            childActive ? 'text-primary font-medium' : 'text-text-heading',
                          ]}
                        >
                          {child.label}
                        </a>
                      </li>
                    );
                  })}
                </div>
              </ul>
            )}
          </li>
        );
      })}
    </ul>

    <!-- CTA Button -->
    <a
      href="/donate"
      class="shrink-0 rounded-full bg-primary px-5 py-2.5 font-heading text-sm font-medium text-white transition-colors hover:bg-primary-hover focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
    >
      Support Healing
    </a>
  </div>
</nav>

<style>
  /* Solid cream bar that blends with the page; bottom border fades in on scroll */
  nav#desktop-nav {
    border-bottom: 1px solid transparent;
    transition: border-color 200ms ease-out;
  }
  nav#desktop-nav.nav-scrolled {
    border-bottom-color: rgba(38, 38, 38, 0.08);
  }

  /* Active item: 2px teal underline directly below the text (selector hook = aria-current) */
  nav#desktop-nav a[aria-current='page'] {
    position: relative;
  }
  nav#desktop-nav > div > ul > li > a[aria-current='page']::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -6px;
    height: 2px;
    background-color: var(--color-primary);
  }

  /* Dropdown reveal */
  li[data-dropdown] > ul {
    transition: opacity 0.15s ease, visibility 0.15s ease;
    transition-delay: 0.05s;
  }
  li[data-dropdown]:hover > ul,
  li[data-dropdown]:focus-within > ul {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition-delay: 0s;
  }
  li[data-dropdown]:hover > a svg,
  li[data-dropdown]:focus-within > a svg {
    transform: rotate(180deg);
  }
</style>

<script>
  const nav = document.getElementById('desktop-nav');
  if (nav) {
    let ticking = false;
    const update = () => {
      if (window.scrollY > 0) {
        nav.classList.add('nav-scrolled');
      } else {
        nav.classList.remove('nav-scrolled');
      }
      ticking = false;
    };
    update();
    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          window.requestAnimationFrame(update);
          ticking = true;
        }
      },
      { passive: true }
    );
  }

  // Keep aria-expanded in sync with hover/focus open state on dropdown triggers
  document.querySelectorAll<HTMLLIElement>('nav#desktop-nav li[data-dropdown]').forEach((li) => {
    const trigger = li.querySelector<HTMLAnchorElement>(':scope > a');
    if (!trigger) return;
    const setOpen = (open: boolean) => trigger.setAttribute('aria-expanded', String(open));
    li.addEventListener('mouseenter', () => setOpen(true));
    li.addEventListener('mouseleave', () => setOpen(false));
    li.addEventListener('focusin', () => setOpen(true));
    li.addEventListener('focusout', (e) => {
      const next = e.relatedTarget as Node | null;
      if (!next || !li.contains(next)) setOpen(false);
    });
  });
</script>
