---
interface Props {
  title: string;
  description: string;
  tags: string[];
  href: string;
  image?: string;
}

const { title, description, tags, href, image } = Astro.props;
---

<article class="group overflow-hidden rounded-[24px] border-[0.5px] border-border-card bg-white shadow-[0px_16px_32px_rgba(12,12,13,0.1),0px_4px_4px_rgba(12,12,13,0.05)] transition-shadow hover:shadow-[0px_20px_40px_rgba(12,12,13,0.14),0px_6px_6px_rgba(12,12,13,0.07)]">
  <a href={href} class="block">
    {image ? (
      <img src={image} alt={title} class="h-48 w-full object-cover" style="object-position: center 20%" width="600" height="400" loading="lazy" />
    ) : (
      <div class="h-48 bg-gradient-to-br from-[#c4a882]/40 to-[#8b6d4a]/20"></div>
    )}
    <div class="p-5">
      <h3 class="font-body text-lg font-medium leading-7 text-text-heading">
        {title}
      </h3>
      <p class="mt-2 font-body text-sm font-normal leading-6 text-text-body">
        {description}
      </p>
      {tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="rounded-full border border-primary/30 px-2.5 py-0.5 font-body text-xs font-medium text-primary">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>
  </a>
</article>
