---
interface RelatedRecipe {
  title: string;
  description: string;
  slug: string;
  image?: string;
}

interface Props {
  title: string;
  description: string;
  culturalContext?: string;
  ingredients: string[];
  instructions: string[];
  image?: string;
  prepTime?: string;
  cookTime?: string;
  servings?: string;
  difficulty?: string;
  author?: string;
  date?: string;
  notes?: string;
  relatedRecipes?: RelatedRecipe[];
}

const {
  title,
  description,
  culturalContext,
  ingredients,
  instructions,
  image,
  prepTime = '15 min',
  cookTime = '30 min',
  servings = '6\u20138',
  difficulty = 'Easy',
  author,
  date,
  notes,
  relatedRecipes = [],
} = Astro.props;
---

<section id="recipe-page" class="pb-16 pt-8 md:pb-20 md:pt-12">
  <div class="mx-auto max-w-[1200px] px-6">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-8 pt-20">
      <ol class="flex flex-wrap items-center gap-1.5 font-body text-sm text-text-muted">
        <li><a href="/community/fighting-antisemitism" class="transition-colors hover:text-primary">Community</a></li>
        <li aria-hidden="true" class="text-text-muted">&rsaquo;</li>
        <li><a href="/community/recipes" class="transition-colors hover:text-primary">Recipes</a></li>
        <li aria-hidden="true" class="text-text-muted">&rsaquo;</li>
        <li class="font-medium text-text-heading">{title}</li>
      </ol>
    </nav>

    <!-- Hero area: image + title -->
    <div class="flex flex-col gap-8 lg:flex-row lg:gap-12">
      <!-- Image -->
      <div class="lg:w-[40%] lg:shrink-0">
        {image ? (
          <img src={image} alt={title} class="aspect-[4/3] w-full overflow-hidden rounded-[16px] object-cover" style="object-position: center 20%" width="600" height="400" loading="eager" />
        ) : (
          <div class="aspect-[4/3] overflow-hidden rounded-[16px] bg-gradient-to-br from-[#c4a882]/40 to-[#8b6d4a]/30"></div>
        )}
      </div>

      <!-- Title + description + metadata -->
      <div class="flex flex-col justify-center">
        <h1 class="font-heading text-[clamp(28px,4vw,42px)] font-medium leading-tight text-text-heading">
          {title}
        </h1>
        {(author || date) && (
          <p class="mt-2 font-body text-sm text-text-muted">
            {author && <span>By {author}</span>}
            {author && date && <span> &middot; </span>}
            {date && <span>{date}</span>}
          </p>
        )}
        <p class="mt-4 font-body text-base leading-relaxed text-text-body">
          {description}
        </p>

        <!-- Metadata bar -->
        <div class="mt-6 flex flex-wrap justify-between gap-6 rounded-[12px] border border-[#DADADA] bg-white px-5 py-4">
          <div class="flex items-center gap-2">
            <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/>
              <path d="M12 7v5l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <div>
              <span class="block font-body text-xs text-text-muted">Prep</span>
              <span class="font-body text-sm font-medium text-text-heading">{prepTime}</span>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2Z" stroke="currentColor" stroke-width="1.5"/>
              <path d="M12 6v6h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <div>
              <span class="block font-body text-xs text-text-muted">Cook</span>
              <span class="font-body text-sm font-medium text-text-heading">{cookTime}</span>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.5"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <div>
              <span class="block font-body text-xs text-text-muted">Servings</span>
              <span class="font-body text-sm font-medium text-text-heading">{servings}</span>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <div>
              <span class="block font-body text-xs text-text-muted">Difficulty</span>
              <span class="font-body text-sm font-medium text-text-heading">{difficulty}</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Cultural context -->
    {culturalContext && (
      <div class="mt-12 rounded-[16px] border-l-4 border-primary bg-[#E8F4F8] px-6 py-5">
        <div class="font-body text-base leading-relaxed text-text-body italic" set:html={culturalContext} />
      </div>
    )}

    <!-- Ingredients + Instructions -->
    <div class="mt-12 flex flex-col gap-12 lg:flex-row lg:gap-16">
      <!-- Ingredients -->
      <div class="lg:w-[35%] lg:shrink-0">
        <h2 class="font-heading text-2xl font-medium text-text-heading">
          Ingredients
        </h2>
        <ul class="mt-5 space-y-3" id="ingredient-list">
          {ingredients.map((ingredient, i) => (
            <li class="ingredient-item flex cursor-pointer items-start gap-3" data-index={i}>
              <span class="ingredient-checkbox mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded border border-[#DADADA] bg-white transition-colors">
                <svg class="ingredient-check hidden h-3 w-3 text-white" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                  <path d="M2 6l3 3 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span class="ingredient-text font-body text-sm leading-relaxed text-text-body transition-colors" set:html={ingredient}>
              </span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Instructions -->
      <div class="lg:flex-1">
        <h2 class="font-heading text-2xl font-medium text-text-heading">
          Instructions
        </h2>
        <ol class="mt-5 space-y-6">
          {instructions.map((step, index) => (
            <li class="flex gap-4">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary font-heading text-sm font-medium text-white">
                {index + 1}
              </span>
              <div class="flex-1 rounded-[12px] border border-[#DADADA] bg-white px-5 py-4">
                <p class="font-body text-sm leading-relaxed text-text-body" set:html={step} />
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>

    <!-- Chef's notes -->
    {notes && (
      <div class="mt-10 rounded-[16px] border border-[#DADADA] bg-white px-6 py-5">
        <h3 class="font-heading text-lg font-medium text-text-heading">Chef's Notes</h3>
        <p class="mt-2 font-body text-sm leading-relaxed text-text-body" set:html={notes} />
      </div>
    )}

    <!-- Share / Print card -->
    <div class="mt-12 flex flex-col items-center gap-4 rounded-[16px] border-[0.5px] border-border-card bg-white px-6 py-6 shadow-[0px_16px_32px_rgba(12,12,13,0.1),0px_4px_4px_rgba(12,12,13,0.05)] sm:flex-row sm:justify-between">
      <div>
        <h3 class="font-heading text-lg font-medium text-text-heading">
          Share This Recipe
        </h3>
        <p class="mt-1 font-body text-sm leading-6 text-text-body">
          This recipe is shared with love from our community. We hope it brings warmth and sweetness to your table.
        </p>
      </div>
      <div class="flex shrink-0 gap-3">
        <button
          type="button"
          id="copy-link-btn"
          class="inline-flex items-center gap-2 rounded-[100px] border border-[#DADADA] bg-white px-5 py-2.5 font-heading text-sm font-medium text-text-heading transition-colors hover:border-primary hover:text-primary"
        >
          <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M6.5 9.5l3-3M7 5.5l-.354-.354a2.5 2.5 0 1 0-3.536 3.536L4.5 10m4.5-4l1.354 1.354a2.5 2.5 0 0 1-3.536 3.536L5.5 9.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span id="copy-link-text">Copy Link</span>
        </button>
        <button
          type="button"
          class="print-recipe-btn inline-flex items-center gap-2 rounded-[100px] bg-primary px-5 py-2.5 font-heading text-sm font-medium text-white transition-colors hover:bg-primary-hover"
        >
          <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M4 6V1h8v5M4 12H2.5A1.5 1.5 0 0 1 1 10.5v-3A1.5 1.5 0 0 1 2.5 6h11A1.5 1.5 0 0 1 15 7.5v3a1.5 1.5 0 0 1-1.5 1.5H12m-8 0h8v3H4v-3Z" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Print Recipe
        </button>
      </div>
    </div>

    <!-- Related Recipes -->
    {relatedRecipes.length > 0 && (
      <div class="mt-16">
        <h2 class="text-center font-heading text-[clamp(24px,3.5vw,32px)] font-medium leading-tight text-text-heading">
          More from Our Table
        </h2>
        <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {relatedRecipes.map((recipe) => (
            <a href={`/community/recipes/${recipe.slug}`} class="group overflow-hidden rounded-[24px] border-[0.5px] border-border-card bg-white shadow-[0px_16px_32px_rgba(12,12,13,0.1),0px_4px_4px_rgba(12,12,13,0.05)] transition-shadow hover:shadow-[0px_20px_40px_rgba(12,12,13,0.14),0px_6px_6px_rgba(12,12,13,0.07)]">
              {recipe.image ? (
                <img src={recipe.image} alt={recipe.title} class="h-48 w-full object-cover" style="object-position: center 20%" width="600" height="400" loading="lazy" />
              ) : (
                <div class="h-48 bg-gradient-to-br from-[#c4a882]/40 to-[#8b6d4a]/20"></div>
              )}
              <div class="p-5">
                <h3 class="font-body text-lg font-medium leading-7 text-text-heading">{recipe.title}</h3>
                <p class="mt-2 font-body text-sm font-normal leading-6 text-text-body">{recipe.description}</p>
              </div>
            </a>
          ))}
        </div>
        <div class="mt-8 text-center">
          <a href="/community/recipes" class="inline-block font-body text-sm font-medium text-primary transition-colors hover:text-primary-hover">
            View All Recipes &rarr;
          </a>
        </div>
      </div>
    )}
  </div>
</section>

<script>
  // Ingredient checkbox toggle
  document.querySelectorAll('.ingredient-item').forEach((item) => {
    item.addEventListener('click', () => {
      const checkbox = item.querySelector('.ingredient-checkbox') as HTMLElement;
      const check = item.querySelector('.ingredient-check') as HTMLElement;
      const text = item.querySelector('.ingredient-text') as HTMLElement;
      const isChecked = !check.classList.contains('hidden');

      if (isChecked) {
        check.classList.add('hidden');
        checkbox.classList.remove('bg-primary', 'border-primary');
        checkbox.classList.add('bg-white', 'border-[#DADADA]');
        text.classList.remove('line-through', 'text-text-muted');
        text.classList.add('text-text-body');
      } else {
        check.classList.remove('hidden');
        checkbox.classList.add('bg-primary', 'border-primary');
        checkbox.classList.remove('bg-white', 'border-[#DADADA]');
        text.classList.add('line-through', 'text-text-muted');
        text.classList.remove('text-text-body');
      }
    });
  });

  // Print
  document.querySelectorAll('.print-recipe-btn').forEach((btn) => {
    btn.addEventListener('click', () => window.print());
  });

  // Copy link
  const copyBtn = document.getElementById('copy-link-btn');
  const copyText = document.getElementById('copy-link-text');
  if (copyBtn && copyText) {
    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        copyText.textContent = 'Copied!';
        setTimeout(() => { copyText.textContent = 'Copy Link'; }, 2000);
      } catch {
        copyText.textContent = 'Copy failed';
        setTimeout(() => { copyText.textContent = 'Copy Link'; }, 2000);
      }
    });
  }
</script>
