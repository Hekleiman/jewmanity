---
interface Props {
  heading?: string;
  description?: string;
  button1Text?: string;
  button1Url?: string;
  button2Text?: string;
  button2Url?: string;
}

const {
  heading = 'Ready to Begin Your Mitzvah Project?',
  description = "Reach out to the Jewmanity team today. We\u2019d love to meet you, hear your story, and help you make your bar or bat mitzvah truly unforgettable.",
  button1Text = 'Start Your Project',
  button1Url = '/get-involved/contact',
  button2Text = 'Download Project Guide',
  button2Url = '/jewmanity-bar-bat-mitzvah-project.pdf',
} = Astro.props;

const isDownload = button2Url?.endsWith('.pdf');
---

<section class="py-16 md:py-20 lg:py-24">
  <div class="mx-auto max-w-[700px] px-6 text-center" data-animate="fade-up">
    <h2 class="font-heading text-[clamp(28px,4vw,36px)] font-medium leading-tight text-text-heading">
      {heading}
    </h2>
    <p class="mx-auto mt-4 max-w-[600px] font-heading text-[clamp(16px,2.2vw,20px)] font-normal leading-relaxed text-text-body">
      {description}
    </p>
    <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href={button1Url}
        class="inline-block rounded-[100px] bg-primary px-8 py-3 font-heading text-base font-medium text-white transition-colors hover:bg-primary-hover"
      >
        {button1Text}
      </a>
      <a
        href={button2Url}
        download={isDownload ? '' : undefined}
        class="inline-block rounded-[100px] border-2 border-primary px-8 py-3 font-heading text-base font-medium text-primary transition-colors hover:bg-primary hover:text-white"
      >
        {button2Text}
      </a>
    </div>
  </div>
</section>
