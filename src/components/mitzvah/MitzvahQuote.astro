---
interface Props {
  quote: string;
  attribution?: string;
}

const { quote, attribution } = Astro.props;
---

<section class="bg-bg-section-alt py-14 md:py-16">
  <div class="mx-auto max-w-[750px] px-6 text-center" data-animate="fade-up">
    <blockquote>
      <span class="mb-2 block font-heading text-[40px] leading-none text-primary" aria-hidden="true">&ldquo;</span>
      <p class="font-heading text-[clamp(18px,2.5vw,22px)] font-normal italic leading-relaxed text-text-heading">
        {quote}
      </p>
      {attribution && (
        <footer class="mt-4 font-body text-sm font-medium uppercase tracking-wider text-text-muted">
          &mdash; {attribution}
        </footer>
      )}
    </blockquote>
  </div>
</section>
