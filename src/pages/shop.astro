---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/shared/HeroSection.astro';
import ImpactSection from '../components/shop/ImpactSection.astro';
import ProductGrid from '../components/shop/ProductGrid.astro';
import CTASection from '../components/shared/CTASection.astro';
import { getProducts } from '../lib/sanity';

let cmsProducts: { id: string; name: string; price: string; priceNum: string; slug: string; description: string; image: string }[] = [];
try {
  const raw = await getProducts();
  cmsProducts = raw.map((p: any) => ({
    id: p.slug?.current || p._id,
    name: p.title,
    price: p.price ? `$${p.price}` : '',
    priceNum: p.price ? p.price.toFixed(2) : '0.00',
    slug: p.slug?.current || '',
    description: p.description || '',
    image: p.image ? '' : '',
  }));
} catch (e) {
  console.warn('Sanity fetch failed for products, using fallback content');
}
---
<Layout title="Shop with Purpose | Jewmanity" description="Support Jewmanity's healing programs with every purchase. Shop merchandise that makes a difference.">
  <HeroSection
    heading="Shop with Purpose"
    subtitle="Wear your values. Every purchase directly supports Jewmanity's healing programs."
    ctaText="Shop Our Collection"
    ctaHref="#product-grid"
    backgroundImage="/images/hero/shop.jpg"
  />
  <ImpactSection />
  <ProductGrid products={cmsProducts.length > 0 ? cmsProducts : undefined} />
  <CTASection
    heading="Support Healing Through Everyday Actions"
    subtitle="Your choice to shop with purpose makes a real difference in someone's healing journey."
    primaryCta={{ text: 'Learn About Heads Up', href: '/programs/heads-up' }}
  />
</Layout>
