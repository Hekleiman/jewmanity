---
import Layout from '../../layouts/Layout.astro';
import HeroSection from '../../components/shared/HeroSection.astro';
import AntisemitismIntro from '../../components/community/AntisemitismIntro.astro';
import ResourcesGrid from '../../components/community/ResourcesGrid.astro';
import StandTogether from '../../components/community/StandTogether.astro';
import CTASection from '../../components/shared/CTASection.astro';
---
<Layout title="Responding to Antisemitism | Jewmanity" description="Educational resources and community support for understanding, responding to, and healing from antisemitism.">
  <HeroSection
    heading="Responding to Antisemitism"
    subtitle="Building understanding and resilience through education, dialogue, and responses rooted in compassion and empathy."
    {/* TODO: Replace with real photo from client */}
    backgroundImage="/images/hero/fighting-antisemitism.jpg"
  />
  <AntisemitismIntro />
  <StandTogether />
  <ResourcesGrid />
  <CTASection
    heading="Stand With Us Against Antisemitism"
    subtitle="Whether you volunteer, donate, or simply share what you've learned, your actions help build a world where Jewish communities can thrive without fear."
    primaryCta={{ text: 'Get Involved', href: '/get-involved/volunteer' }}
    secondaryCta={{ text: 'Support Healing', href: '/donate' }}
  />
</Layout>
