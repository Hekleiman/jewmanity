---
import Layout from '../../layouts/Layout.astro';
import HeroSection from '../../components/shared/HeroSection.astro';
import TeamGrid from '../../components/about/TeamGrid.astro';
import CTASection from '../../components/shared/CTASection.astro';
import { getTeamMembers } from '../../lib/sanity';

let cmsMembers: { name: string; role: string; bio: string }[] = [];
try {
  const raw = await getTeamMembers();
  cmsMembers = raw.map((m: any) => ({
    name: m.name,
    role: m.role || '',
    bio: m.bio || '',
  }));
} catch (e) {
  console.warn('Sanity fetch failed for team members, using fallback content');
}
---
<Layout title="Our Team | Jewmanity" description="Meet the dedicated leaders, advocates, and community members behind Jewmanity's mission of healing and resilience.">
  <HeroSection
    heading="Meet the People Behind Jewmanity"
    subtitle="A dedicated team united by compassion, lived experience, and a commitment to building resilience in our community."
    backgroundImage="/images/hero/about-team.jpg"
  />
  <TeamGrid members={cmsMembers.length > 0 ? cmsMembers : undefined} />
  <CTASection
    heading="Be Part of the Work We Do"
    subtitle="Join a growing community committed to service, responsibility, and impact."
    primaryCta={{ text: 'Learn How to Get Involved', href: '/get-involved/volunteer' }}
  />
</Layout>
