---
import Layout from '../../layouts/Layout.astro';
import HeroSection from '../../components/shared/HeroSection.astro';
import StoriesGrid from '../../components/about/StoriesGrid.astro';
import CTASection from '../../components/shared/CTASection.astro';
import { getCommunityStories } from '../../lib/sanity';

let cmsStories: { title: string; description: string }[] = [];
try {
  const raw = await getCommunityStories();
  cmsStories = raw.map((s: any) => ({
    title: s.title,
    description: s.description || '',
  }));
} catch (e) {
  console.warn('Sanity fetch failed for community stories, using fallback content');
}
---
<Layout title="Community Stories | Jewmanity" description="Inspiring stories of compassion, service, and solidarity from Jewish communities around the world.">
  <HeroSection
    heading="Community Stories"
    subtitle="Celebrating the legacy of care, resilience, and humanity that defines Jewish communities around the world"
    backgroundImage="/images/hero/community-stories.jpg"
  />

  <section id="intro" class="py-16 md:py-20 lg:py-24">
    <div class="mx-auto max-w-[800px] px-6 text-center">
      <div class="space-y-6">
        <p class="font-body text-[15px] leading-relaxed text-text-body md:text-base">
          For thousands of years, Jewish communities have embodied a commitment to compassion, service, and mutual responsibility. This is not a recent response to crisis—it is woven into the fabric of our identity.
        </p>
        <p class="font-body text-[15px] leading-relaxed text-text-body md:text-base">
          From ancient traditions of caring for the stranger to modern innovations in medical aid and social services, these stories reflect a timeless dedication to human dignity and the belief that we are all responsible for one another.
        </p>
      </div>
    </div>
  </section>

  <StoriesGrid stories={cmsStories.length > 0 ? cmsStories : undefined} />

  <CTASection
    heading="Be Part of the Ongoing Story"
    subtitle="Every act of care, every moment of connection, every gesture of support adds a new chapter to this living legacy. Join us in building a more compassionate world."
    primaryCta={{ text: 'Get Involved', href: '/get-involved/volunteer' }}
  />
</Layout>
