---
import Layout from '../../layouts/Layout.astro';
import HeroSection from '../../components/shared/HeroSection.astro';
import ContactForm from '../../components/contact/ContactForm.astro';
import OtherWays from '../../components/contact/OtherWays.astro';
import { getContactPage, urlFor } from '../../lib/sanity';

let cms: Record<string, any> | null = null;
try {
  cms = await getContactPage();
} catch (e) {
  console.warn('Sanity fetch failed for contactPage, using hardcoded fallbacks');
}

const heroBg = cms?.hero?.backgroundImage
  ? urlFor(cms.hero.backgroundImage).width(1920).quality(80).url()
  : '/images/hero/contact.jpg';

const introText =
  cms?.introText ||
  "We're here to listen and support you. Whether you have questions about our programs, need support resources, are interested in partnership opportunities, or simply want to connect, please reach out. All inquiries are handled with respect and confidentiality.";
---
<Layout title="Contact Us | Jewmanity" description="Get in touch with Jewmanity. We welcome your questions, stories, and inquiries about our programs and mission.">
  <HeroSection
    heading={cms?.hero?.heading ?? 'Get in Touch'}
    subtitle={cms?.hero?.subtitle ?? 'We welcome your questions, stories, and inquiries. This is a safe space for open conversation and meaningful connection.'}
    backgroundImage={heroBg}
  />

  <!-- Intro prose -->
  <section id="contact-intro" class="py-16 md:py-20">
    <div class="mx-auto max-w-[800px] px-6 text-center">
      <p class="font-heading text-[clamp(16px,2.2vw,18px)] font-normal leading-relaxed text-text-body">
        {introText}
      </p>
    </div>
  </section>

  <ContactForm
    heading={cms?.formHeading}
    privacyNote={cms?.privacyNote}
  />
  <OtherWays
    heading={cms?.otherWaysHeading}
    cards={cms?.otherWaysCards}
  />
</Layout>
