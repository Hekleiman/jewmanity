---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/shared/HeroSection.astro';
import AdvocacyPillars from '../components/resources/AdvocacyPillars.astro';
import WhyThisMatters from '../components/resources/WhyThisMatters.astro';
import CommonStruggles from '../components/resources/CommonStruggles.astro';
import SignsSection from '../components/resources/SignsSection.astro';
import CrisisResources from '../components/resources/CrisisResources.astro';
---
<Layout title="Mental Health Resources | Jewmanity" description="Mental health awareness resources, crisis support information, and guidance for those navigating trauma, depression, anxiety, and PTSD.">
  <HeroSection
    heading="You Are Not Alone"
    subtitle="Struggling with anxiety, depression, trauma, or emotional overwhelm can feel isolating. It doesn't have to be. Jewmanity stands in advocacy, compassion, and connection for those navigating mental health challenges."
    backgroundImage="/images/hero/resources.jpg"
  />
  <AdvocacyPillars />
  <WhyThisMatters />
  <CommonStruggles />
  <SignsSection />
  <CrisisResources />
</Layout>
