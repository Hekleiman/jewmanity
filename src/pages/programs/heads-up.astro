---
import Layout from '../../layouts/Layout.astro';
import HeroSection from '../../components/shared/HeroSection.astro';
import SafeHaven from '../../components/programs/SafeHaven.astro';
import WhoWeSupport from '../../components/programs/WhoWeSupport.astro';
import RetreatExperience from '../../components/programs/RetreatExperience.astro';
import EvidenceBasedCare from '../../components/programs/EvidenceBasedCare.astro';
import WhatsIncluded from '../../components/programs/WhatsIncluded.astro';
import CommunityPowered from '../../components/programs/CommunityPowered.astro';
import ImpactStats from '../../components/programs/ImpactStats.astro';
import TestimonialCarousel from '../../components/shared/TestimonialCarousel.astro';
import CTASection from '../../components/shared/CTASection.astro';
import { getHeadsUp, getTestimonials, urlFor, urlForCropped } from '../../lib/sanity';

interface PortableBlock {
  _type: string;
  style?: string;
  listItem?: string;
  children?: { text?: string }[];
}

function extractParagraphs(blocks: PortableBlock[] | undefined): string[] {
  if (!Array.isArray(blocks)) return [];
  return blocks
    .filter((b) => b._type === 'block' && !b.listItem && (b.style === 'normal' || !b.style))
    .map((b) => (b.children || []).map((c) => c.text || '').join(''))
    .filter((t) => t.length > 0);
}

let cms: Record<string, any> | null = null;
try {
  cms = await getHeadsUp();
} catch (e) {
  console.warn('Sanity fetch failed for headsUp, using hardcoded fallbacks');
}

const heroBg = cms?.hero?.backgroundImage
  ? urlFor(cms.hero.backgroundImage).width(1920).quality(80).url()
  : '/images/hero/heads-up.jpg';

const safeHavenImage = cms?.safeHavenImage ? urlFor(cms.safeHavenImage).width(800).quality(80).url() : undefined;
const careImage = cms?.careImage ? urlFor(cms.careImage).width(800).quality(80).url() : undefined;
const communityImage = cms?.communityImage ? urlFor(cms.communityImage).width(800).quality(80).url() : undefined;

const safeHavenParagraphs = extractParagraphs(cms?.safeHavenBody);

const ctaPrimary = cms?.ctaPrimaryButton?.text && cms?.ctaPrimaryButton?.href
  ? cms.ctaPrimaryButton
  : { text: 'Support Healing', href: '/donate' };

let cmsTestimonials: { quote: string; author: string; context: string; imageUrl?: string }[] = [];
try {
  const raw = await getTestimonials('headsup');
  cmsTestimonials = raw.map((t: any) => ({
    quote: t.excerpt || t.quote,
    author: t.authorName || '',
    context: t.authorRole || '',
    imageUrl: t.imageUrl
      ? t.imageUrl
      : t.authorImage
        ? urlForCropped(t.authorImage, 224, 224).url()
        : undefined,
  }));
} catch (e) {
  console.warn('Sanity fetch failed for headsup testimonials, using fallback content');
}

const fallbackTestimonials = [
  {
    quote: 'After October 7th, I lost my faith — especially in myself. Through Jewmanity, I spent a month in the U.S. healing and being supported by professional care. This journey helped me believe in myself again.',
    author: 'Matan Balahsan',
    context: 'Heads Up Participant',
    imageUrl: '/images/testimonials/matan.png',
  },
];
---
<Layout title="Heads Up Healing Retreats | Jewmanity" description="A comprehensive rehabilitation retreat in San Diego supporting Israeli soldiers and their loved ones experiencing PTSD and ongoing trauma.">
  <HeroSection
    heading={cms?.hero?.heading ?? 'Heads Up'}
    subtitle={cms?.hero?.subtitle ?? 'A comprehensive rehabilitation retreat in San Diego, designed to support Israeli soldiers and their loved ones experiencing PTSD and ongoing trauma'}
    backgroundImage={heroBg}
  />
  <SafeHaven
    heading={cms?.safeHavenHeading}
    paragraphs={safeHavenParagraphs.length > 0 ? safeHavenParagraphs : undefined}
    imageUrl={safeHavenImage}
  />
  <WhoWeSupport
    heading={cms?.supportHeading}
    subtitle={cms?.supportSubtitle}
    cards={cms?.supportCards}
  />
  <RetreatExperience
    heading={cms?.experienceHeading}
    subtitle={cms?.experienceSubtitle}
    items={cms?.experienceItems}
  />
  <EvidenceBasedCare
    heading={cms?.careHeading}
    imageUrl={careImage}
    pillars={cms?.carePillars}
  />
  <WhatsIncluded
    heading={cms?.includedHeading}
    subtitle={cms?.includedSubtitle}
    items={cms?.includedItems}
  />
  <CommunityPowered
    heading={cms?.communityHeading}
    intro={cms?.communityIntro}
    bullets={cms?.communityBullets}
    button={cms?.communityButton}
    imageUrl={communityImage}
  />
  <TestimonialCarousel
    heading="Voices from Heads Up"
    subtitle="Honest reflections from soldiers who found healing, connection, and renewed strength through our retreats."
    testimonials={cmsTestimonials.length > 0 ? cmsTestimonials : fallbackTestimonials}
  />
  <ImpactStats
    heading={cms?.impactHeading}
    subtitle={cms?.impactSubtitle}
    stats={cms?.impactStats}
  />
  <CTASection
    heading={cms?.ctaHeading ?? 'Creating Space for Healing'}
    subtitle={cms?.ctaSubtitle ?? 'Healing from trauma requires safety, compassion, and community. Your support helps us provide these essential spaces where Israeli soldiers and their loved ones can begin to recover, reconnect, and rebuild.'}
    primaryCta={ctaPrimary}
  />
</Layout>
