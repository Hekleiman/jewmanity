---
import Layout from '../../layouts/Layout.astro';
import RetreatArticle from '../../components/programs/RetreatArticle.astro';
import { getRetreats } from '../../lib/sanity';

interface RetreatData {
  title: string;
  subtitle: string;
  author: string;
}

const fallbackRetreatData: Record<string, RetreatData> = {
  'first-retreat': {
    title: 'Heads Up Retreat #1 \u2013 \u201CThe Beginning\u201D',
    subtitle: 'Spring in San Diego',
    author: 'Written by retreat assistant, Kate H.',
  },
  'second-retreat': {
    title: 'Heads Up Retreat #2 \u2013 \u201CBuilding Bridges\u201D',
    subtitle: 'Spring in San Diego',
    author: 'Written by retreat coordinator, Sarah M.',
  },
  'third-retreat': {
    title: 'Heads Up Retreat #3 \u2013 \u201CRising Together\u201D',
    subtitle: 'Summer in San Diego',
    author: 'Written by volunteer, James R.',
  },
  'fourth-retreat': {
    title: 'Heads Up Retreat #4 \u2013 \u201CFathers, Fighters\u201D',
    subtitle: 'Winter in San Diego',
    author: 'Written by retreat assistant, Kate H.',
  },
};

const fallbackPaths = [
  { params: { slug: 'example' } },
  { params: { slug: 'first-retreat' } },
  { params: { slug: 'second-retreat' } },
  { params: { slug: 'third-retreat' } },
  { params: { slug: 'fourth-retreat' } },
];

export async function getStaticPaths() {
  let retreats: any[] = [];
  try {
    retreats = await getRetreats();
  } catch (e) {
    console.warn('Sanity fetch failed for retreat paths, using fallback');
  }

  if (retreats.length > 0) {
    return retreats.map((retreat: any) => ({
      params: { slug: retreat.slug.current },
      props: { retreat },
    }));
  }

  return [
    { params: { slug: 'example' } },
    { params: { slug: 'first-retreat' } },
    { params: { slug: 'second-retreat' } },
    { params: { slug: 'third-retreat' } },
    { params: { slug: 'fourth-retreat' } },
  ];
}

const { slug } = Astro.params;
const cmsRetreat = Astro.props.retreat || null;
const data = cmsRetreat
  ? { title: cmsRetreat.title, subtitle: cmsRetreat.subtitle || '', author: cmsRetreat.author || '' }
  : fallbackRetreatData[slug as string];
---
<Layout title={`${data ? data.title : slug} | Jewmanity`} description="Read about this transformative Heads Up healing retreat experience.">
  {data ? (
    <RetreatArticle
      title={data.title}
      subtitle={data.subtitle}
      author={data.author}
    />
  ) : (
    <div class="flex min-h-screen flex-col items-center justify-center gap-4">
      <h1 class="font-heading text-3xl font-medium text-text-heading">{slug}</h1>
      <p class="text-text-muted">Dynamic page — Phase 1</p>
    </div>
  )}
</Layout>
