---
import Layout from '../../layouts/Layout.astro';
import RetreatArticle from '../../components/programs/RetreatArticle.astro';
import { getRetreats, urlFor } from '../../lib/sanity';

interface ContentBlock {
  type: 'paragraph' | 'heading' | 'image';
  level?: 'h2' | 'h3' | 'h4' | 'h5' | 'h6';
  text?: string;
  src?: string;
  alt?: string;
}

export async function getStaticPaths() {
  const retreats = await getRetreats();
  return retreats.map((retreat: Record<string, unknown>) => ({
    params: { slug: (retreat.slug as { current: string }).current },
    props: { retreat },
  }));
}

const { retreat } = Astro.props as { retreat: Record<string, unknown> };

const title = (retreat.title as string) || 'Retreat';
const subtitle = (retreat.subtitle as string) || '';
const author = (retreat.author as string) || '';
const coverImage = retreat.coverImage
  ? urlFor(retreat.coverImage as any).width(1920).url()
  : '/images/hero/retreat-article.jpg';

const cmsGallery = retreat.gallery as Record<string, unknown>[] | undefined;
const gallery: { url: string; alt?: string }[] = Array.isArray(cmsGallery)
  ? cmsGallery
      .filter((g) => (g as any)?.asset)
      .map((g) => ({ url: urlFor(g as any).width(1280).url(), alt: (g.alt as string) || undefined }))
  : [];

const HEADING_STYLES = new Set(['h2', 'h3', 'h4', 'h5', 'h6']);

const cmsBody = (retreat.body as Record<string, unknown>[] | undefined) ?? [];
const body: ContentBlock[] = cmsBody.map((block) => {
  if (block._type === 'image' && block.asset) {
    return {
      type: 'image' as const,
      src: urlFor(block as any).width(1280).url(),
      alt: (block.alt as string) || title,
    };
  }
  const style = block.style as string;
  const children = block.children as { text: string }[] | undefined;
  const text = children?.map((c) => c.text).join('') || '';
  if (HEADING_STYLES.has(style)) {
    return { type: 'heading' as const, level: style as ContentBlock['level'], text };
  }
  return { type: 'paragraph' as const, text };
});
---

<Layout title={`${title} | Jewmanity`} description="Read about this transformative Heads Up healing retreat experience.">
  <RetreatArticle
    title={title}
    subtitle={subtitle}
    author={author}
    coverImage={coverImage}
    body={body}
    gallery={gallery}
  />
</Layout>
