PUBLIC_SANITY_PROJECT_ID=9pc3wgri
PUBLIC_SANITY_DATASET=production

# Snipcart public API key. Get from Snipcart dashboard → Account → API Keys.
# - Test key: works in Snipcart's sandbox (no real charges)
# - Live key: processes real payments
# If unset or empty, the codebase falls back to a hardcoded TEST key (safe for local dev).
PUBLIC_SNIPCART_API_KEY=

SANITY_API_TOKEN=your_sanity_write_token
ANTHROPIC_API_KEY=your_api_key
